{% extends 'base.html.twig' %}

{% block title %}Indicateurs de Période
{% endblock %}

{% block header_title %}Indicateurs de Période
{% endblock %}
{% block header_subtitle %}Agrégats & Orientation Politique Monétaire
{% endblock %}

{% block stylesheets %}
	<style>
		/* ── Tone de page ─────────────────────────────────────────────────────── */
		.page-content {
			background: #f0f4f8;
		}
		[data-theme="dark"] .page-content,
		body.dark-mode .page-content {
			background: #0f172a;
		}

		/* ── Sélecteur de période ────────────────────────────────────────────── */
		.periode-card {
			background: linear-gradient(135deg, #1e4b7a 0%, #2d6da6 100%);
			border-radius: 16px;
			padding: 1.5rem 2rem;
			color: #fff;
			display: flex;
			align-items: center;
			flex-wrap: wrap;
			gap: 1rem;
			margin-bottom: 1.5rem;
			box-shadow: 0 4px 20px rgba(30, 75, 122, 0.35);
		}
		.periode-card label {
			font-weight: 600;
			font-size: 0.85rem;
			letter-spacing: 0.04em;
			opacity: .85;
		}
		.periode-card input[type="date"] {
			background: rgba(255, 255, 255, 0.15);
			border: 1px solid rgba(255, 255, 255, 0.35);
			color: #fff;
			border-radius: 8px;
			padding: 0.45rem 0.9rem;
			font-size: 0.9rem;
			outline: none;
			transition: background 0.2s;
		}
		.periode-card input[type="date"]:focus {
			background: rgba(255, 255, 255, 0.25);
		}
		.periode-card input[type="date"]::-webkit-calendar-picker-indicator {
			filter: invert(1);
		}
		.btn-appliquer {
			background: #f7e034;
			color: #1e4b7a;
			font-weight: 700;
			border: none;
			border-radius: 8px;
			padding: 0.5rem 1.4rem;
			cursor: pointer;
			font-size: 0.9rem;
			transition: all 0.2s;
		}
		.btn-appliquer:hover {
			background: #ffe900;
			transform: translateY(-1px);
		}

		.btn-export {
			background: rgba(255, 255, 255, 0.18);
			color: #fff;
			font-weight: 600;
			border: 1px solid rgba(255, 255, 255, 0.4);
			border-radius: 8px;
			padding: 0.5rem 1.2rem;
			cursor: pointer;
			font-size: 0.85rem;
			text-decoration: none;
			transition: all 0.2s;
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
		}
		.btn-export:hover {
			background: rgba(255, 255, 255, 0.3);
			color: #fff;
		}

		/* ── Bandeau Taux Directeur ──────────────────────────────────────────── */
		.taux-banner {
			border-radius: 16px;
			padding: 1.6rem 2rem;
			margin-bottom: 1.5rem;
			display: flex;
			align-items: flex-start;
			justify-content: space-between;
			gap: 1.5rem;
			flex-wrap: wrap;
			box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
		}
		.taux-banner.success {
			background: linear-gradient(135deg,#d4edda,#c3e6cb);
			border-left: 5px solid #38a169;
		}
		.taux-banner.info {
			background: linear-gradient(135deg,#cfe2ff,#b6d4fe);
			border-left: 5px solid #4a89dc;
		}
		.taux-banner.warning {
			background: linear-gradient(135deg,#fff3cd,#ffeaa7);
			border-left: 5px solid #dd6b20;
		}
		.taux-banner.danger {
			background: linear-gradient(135deg,#f8d7da,#f5c6cb);
			border-left: 5px solid #c53030;
		}
		.taux-banner.secondary {
			background: linear-gradient(135deg,#e9ecef,#dee2e6);
			border-left: 5px solid #adb5bd;
		}

		.taux-gauge {
			font-size: 3.2rem;
			font-weight: 800;
			line-height: 1;
			color: #1e4b7a;
		}
		.taux-label {
			font-size: 0.78rem;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			opacity: .7;
			font-weight: 600;
		}
		.taux-reco-label {
			font-size: 1.25rem;
			font-weight: 700;
			margin-bottom: 0.25rem;
		}
		.taux-reco-justif {
			font-size: 0.88rem;
			line-height: 1.55;
			opacity: .85;
			max-width: 65ch;
		}

		/* ── KPI Cards ──────────────────────────────────────────────────────── */
		.kpi-grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 1rem;
			margin-bottom: 1.5rem;
		}
		@media(max-width: 1100px) {
			.kpi-grid {
				grid-template-columns: repeat(2, 1fr);
			}
		}
		@media(max-width: 600px) {
			.kpi-grid {
				grid-template-columns: 1fr;
			}
		}
		.kpi-card {
			background: var(--bg-card);
			border-radius: 14px;
			padding: 1.25rem 1.5rem 1.35rem;
			box-shadow: 0 2px 14px rgba(0, 0, 0, 0.07);
			border-top: 4px solid rgba(0, 0, 0, 0.08);
			transition: transform 0.18s, box-shadow 0.18s;
			display: flex;
			flex-direction: column;
			gap: 0;
		}
		.kpi-card:hover {
			transform: translateY(-3px);
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.11);
		}
		.kpi-card.signal-green {
			border-top-color: #38a169;
		}
		.kpi-card.signal-yellow {
			border-top-color: #d69e2e;
		}
		.kpi-card.signal-orange {
			border-top-color: #dd6b20;
		}
		.kpi-card.signal-red {
			border-top-color: #c53030;
		}
		.kpi-card.signal-secondary {
			border-top-color: #adb5bd;
		}
		/* Pill signal */
		.kpi-pill {
			display: inline-block;
			font-size: 0.68rem;
			font-weight: 700;
			letter-spacing: 0.05em;
			padding: 0.16rem 0.52rem;
			border-radius: 20px;
			margin-bottom: 0.55rem;
			width: fit-content;
		}
		.pill-green {
			background: #d4edda;
			color: #155724;
		}
		.pill-yellow {
			background: #fff3cd;
			color: #856404;
		}
		.pill-orange {
			background: #ffe5cc;
			color: #8a4700;
		}
		.pill-red {
			background: #f8d7da;
			color: #721c24;
		}
		.pill-secondary {
			background: #e9ecef;
			color: #6c757d;
		}
		/* Valeur principale */
		.kpi-value {
			font-size: 2rem;
			font-weight: 800;
			color: var(--text-primary);
			line-height: 1.05;
			letter-spacing: -0.02em;
		}
		.kpi-subvalue {
			font-size: 0.75rem;
			color: var(--text-secondary);
			margin-top: 0.18rem;
			font-weight: 500;
		}
		/* Titre pilier */
		.kpi-title {
			font-size: 0.78rem;
			font-weight: 700;
			color: var(--text-primary);
			margin-top: 0.9rem;
			padding-top: 0.7rem;
			border-top: 1px solid rgba(0, 0, 0, 0.08);
			display: flex;
			align-items: center;
			gap: 0.3rem;
		}
		/* Mini-grille de sous-données */
		.kpi-data {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.28rem 0.5rem;
			margin-top: 0.6rem;
		}
		.kpi-data-item {
			display: flex;
			flex-direction: column;
		}
		.kdi-label {
			font-size: 0.63rem;
			font-weight: 600;
			color: var(--text-secondary);
			letter-spacing: 0.04em;
			text-transform: uppercase;
			white-space: nowrap;
		}
		.kdi-val {
			font-size: 0.82rem;
			font-weight: 700;
			color: var(--text-primary);
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}

		/* ── Graphiques ─────────────────────────────────────────────────────── */
		.charts-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(440px, 1fr));
			gap: 1.2rem;
			margin-bottom: 1.5rem;
		}
		.chart-card {
			background: var(--bg-card);
			border-radius: 14px;
			padding: 1.2rem 1.4rem;
			box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
		}
		.chart-card h3 {
			font-size: 0.9rem;
			font-weight: 700;
			color: var(--text-primary);
			margin-bottom: 1rem;
			display: flex;
			align-items: center;
			gap: 0.4rem;
		}
		.chart-wrapper {
			position: relative;
			height: 220px;
		}

		/* ── Tableau résumé ─────────────────────────────────────────────────── */
		.summary-card {
			background: var(--bg-card);
			border-radius: 14px;
			padding: 1.4rem;
			box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
			margin-bottom: 1.5rem;
			overflow-x: auto;
		}
		.summary-card h3 {
			font-size: 0.95rem;
			font-weight: 700;
			color: var(--text-primary);
			margin-bottom: 1rem;
		}
		.summary-table {
			width: 100%;
			border-collapse: collapse;
			font-size: 0.83rem;
		}
		.summary-table th {
			background: #1e4b7a;
			color: #fff;
			padding: 0.55rem 0.8rem;
			text-align: left;
			font-size: 0.78rem;
			font-weight: 600;
			letter-spacing: 0.04em;
			white-space: nowrap;
		}
		.summary-table td {
			padding: 0.5rem 0.8rem;
			border-bottom: 1px solid rgba(0, 0, 0, 0.08);
			white-space: nowrap;
		}
		.summary-table tr:hover td {
			background: rgba(0, 0, 0, 0.04);
		}

		/* signal inline badges */
		.badge {
			padding: 0.22rem 0.55rem;
			border-radius: 20px;
			font-size: 0.7rem;
			font-weight: 700;
			display: inline-block;
		}
		.badge-green {
			background: #d4edda;
			color: #155724;
		}
		.badge-yellow {
			background: #fff3cd;
			color: #856404;
		}
		.badge-orange {
			background: #ffe5cc;
			color: #8a4700;
		}
		.badge-red {
			background: #f8d7da;
			color: #721c24;
		}
		.badge-secondary {
			background: #e9ecef;
			color: #6c757d;
		}

		/* ── No-data ────────────────────────────────────────────────────────── */
		.no-data {
			text-align: center;
			padding: 3rem 1rem;
			color: #bbb;
			font-size: 0.95rem;
		}
		.no-data i {
			font-size: 2.5rem;
			display: block;
			margin-bottom: 0.7rem;
		}

		/* Dark mode tweaks */
		[data-theme="dark"] .summary-table th,
		body.dark-mode .summary-table th {
			background: rgba(255, 255, 255, 0.1);
			color: var(--text-secondary);
		}

		[data-theme="dark"] .summary-table tr:hover td,
		body.dark-mode .summary-table tr:hover td {
			background: rgba(255, 255, 255, 0.08);
		}

		[data-theme="dark"] .taux-banner,
		body.dark-mode .taux-banner {
			background: rgba(30, 41, 59, 0.85);
			box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
			color: var(--text-primary);
		}

		[data-theme="dark"] .taux-banner .taux-gauge,
		body.dark-mode .taux-banner .taux-gauge {
			color: var(--text-primary);
		}

		[data-theme="dark"] .taux-banner .taux-label,
		body.dark-mode .taux-banner .taux-label,
		[data-theme="dark"] .taux-banner .taux-reco-label,
		body.dark-mode .taux-banner .taux-reco-label,
		[data-theme="dark"] .taux-banner .taux-reco-justif,
		body.dark-mode .taux-banner .taux-reco-justif {
			color: var(--text-secondary);
		}
	</style>
{% endblock %}

{% block body %}

	{# ── Sélecteur de période ──────────────────────────────────────────────── #}
	<form method="get" action="{{ path('app_indicateurs_periode') }}" class="periode-card">
		<div>
			<label>Du</label>
			<input type="date" name="dateDebut" value="{{ dateDebut }}" required>
		</div>
		<div>
			<label>Au</label>
			<input type="date" name="dateFin" value="{{ dateFin }}" required>
		</div>
		<button type="submit" class="btn-appliquer">
			<i class="fas fa-filter" style="margin-right:.35rem"></i>Appliquer
		</button>
		<a href="{{ path('app_indicateurs_periode_slide', {dateDebut: dateDebut, dateFin: dateFin}) }}" style="background:#ed8004" class="btn-export" target="_blank">
			<i class="fas fa-file-powerpoint" ;"></i>Exporter le Slide
		</a>
		<span style="margin-left:auto; opacity:.7; font-size:.82rem">
			Période :
			{{ dateDebut|date('d/m/Y') }}
			→
			{{ dateFin|date('d/m/Y') }}
			{% if change.nb_jours is defined and change.nb_jours %}
				&nbsp;·&nbsp;
				{{ change.nb_jours }}
				jours observés
			{% endif %}
		</span>
	</form>



	{# ── Grille KPI des 4 Piliers ──────────────────────────────────────────── #}
	{% set pillLabels = {green:'🟢 Normal', yellow:'🟡 Vigilance', orange:'🟠 Alerte', red:'🔴 Critique', secondary:'⚪ N/D'} %}
	<div
		class="kpi-grid">

		{# ─ Pilier 1 : Marché des Changes ─ #}
		<div class="kpi-card signal-{{ signalChange }}">
			<span class="kpi-pill pill-{{ signalChange }}">{{ pillLabels[signalChange] ?? 'N/D' }}</span>
			<div class="kpi-value">
				{% if ecartMoy is not null %}
					{{ ecartMoy|number_format(2, ',', ' ') }}
					%{% else %}N/D
				{% endif %}
			</div>
			<div class="kpi-subvalue">Écart moy. indicatif / parallèle</div>
			<div class="kpi-data">
				<div class="kpi-data-item">
					<span class="kdi-label">Cours indicatif moy.</span>
					<span class="kdi-val">
						{% if change.cours_indicatif_moy is defined and change.cours_indicatif_moy %}
							{{ change.cours_indicatif_moy|number_format(2, ',', ' ') }}
							CDF
							{% else %}—
						{% endif %}
					</span>
				</div>
				<div class="kpi-data-item">
					<span class="kdi-label">Cours parallèle moy.</span>
					<span class="kdi-val">
						{% if change.mid_parallele_moy is defined and change.mid_parallele_moy %}
							{{ change.mid_parallele_moy|number_format(2, ',', ' ') }}
							CDF
							{% else %}—
						{% endif %}
					</span>
				</div>
				<div class="kpi-data-item">
					<span class="kdi-label">Écart nominal moy.</span>
					<span class="kdi-val">
						{% if change.mid_parallele_moy is defined and change.cours_indicatif_moy is defined and change.cours_indicatif_moy %}
							{{ (change.mid_parallele_moy - change.cours_indicatif_moy)|number_format(2, ',', ' ') }}
							CDF
							{% else %}—
						{% endif %}
					</span>
				</div>
				<div class="kpi-data-item">
					<span class="kdi-label">Étendue (min → max)</span>
					<span class="kdi-val">
						{% if ecartMin is not null and ecartMax is not null %}
							{{ ecartMin|number_format(1, ',', ' ') }}
							→
							{{ ecartMax|number_format(1, ',', ' ') }}
							%
							{% else %}—
						{% endif %}
					</span>
				</div>
			</div>
			<div class="kpi-title">🏦 Pilier 1 — Marché des Changes</div>
		</div>

		{# ─ Pilier 2 : Position Extérieure ─ #}
		<div class="kpi-card signal-green">
			<span class="kpi-pill pill-green">🟢 Ancre Externe</span>
			<div class="kpi-value">
				{% if reservesIntMoy is not null %}
					{{ (reservesIntMoy / 1000)|number_format(2, ',', ' ') }}
					Md${% else %}N/D
				{% endif %}
			</div>
			<div class="kpi-subvalue">Réserves int. moyennes (Mds USD)</div>
			<div class="kpi-data">
				<div class="kpi-data-item">
					<span class="kdi-label">Min période</span>
					<span class="kdi-val">
						{% if reserves.reserves_int_min is defined and reserves.reserves_int_min %}
							{{ (reserves.reserves_int_min / 1000)|number_format(2, ',', ' ') }}
							Md$
							{% else %}—
						{% endif %}
					</span>
				</div>
				<div class="kpi-data-item">
					<span class="kdi-label">Max période</span>
					<span class="kdi-val">
						{% if reserves.reserves_int_max is defined and reserves.reserves_int_max %}
							{{ (reserves.reserves_int_max / 1000)|number_format(2, ',', ' ') }}
							Md$
							{% else %}—
						{% endif %}
					</span>
				</div>
				<div class="kpi-data-item">
					<span class="kdi-label">Avoirs extérieurs moy.</span>
					<span class="kdi-val">
						{% if reserves.avoirs_ext_moy is defined and reserves.avoirs_ext_moy %}
							{{ (reserves.avoirs_ext_moy / 1000)|number_format(2, ',', ' ') }}
							Md$
							{% else %}—
						{% endif %}
					</span>
				</div>
				<div class="kpi-data-item">
					<span class="kdi-label">Jours observés</span>
					<span class="kdi-val">
						{% if reserves.nb_jours is defined %}
							{{ reserves.nb_jours }}
							j{% else %}—
						{% endif %}
					</span>
				</div>
			</div>
			<div class="kpi-title">🌍 Pilier 2 — Position Extérieure</div>
		</div>

		{# ─ Pilier 3 : Marché Monétaire ─ #}
		<div class="kpi-card signal-{{ signalLiquidite }}">
			<span class="kpi-pill pill-{{ signalLiquidite }}">{{ pillLabels[signalLiquidite] ?? 'N/D' }}</span>
			<div class="kpi-value">
				{% if avLibresMoy is not null %}
					{{ avLibresMoy|number_format(0, ',', ' ') }}{% else %}N/D
				{% endif %}
			</div>
			<div class="kpi-subvalue">Avoirs Libres moy. (Mds CDF)</div>
			<div class="kpi-data">
				<div class="kpi-data-item">
					<span class="kdi-label">PIC AVOIRS LIBRES</span>
					<span class="kdi-val">
						{% if avLibresMax is not null %}
							{{ avLibresMax|number_format(0, ',', ' ') }} Mds
						{% else %}—
						{% endif %}
					</span>
				</div>
				<div class="kpi-data-item">
					<span class="kdi-label">STÉRILISATION MOY.</span>
					<span class="kdi-val">
						{% if encoursBonsMoy is not null %}
							{{ encoursBonsMoy|number_format(0, ',', ' ') }} Mds
						{% else %}—
						{% endif %}
					</span>
				</div>
				<div class="kpi-data-item">
					<span class="kdi-label">COUVERTURE STÉRIL.</span>
					<span class="kdi-val">
						{% if encoursBonsMoy is not null and avLibresMoy is not null and avLibresMoy > 0 %}
							{{ ((encoursBonsMoy / avLibresMoy) * 100)|number_format(1, ',', ' ') }} %
						{% else %}—
						{% endif %}
					</span>
				</div>
				<div class="kpi-data-item">
					<span class="kdi-label">SEUIL ALERTE</span>
					<span class="kdi-val">
						800 / 1 200 Mds
					</span>
				</div>
				{% if soldeCgtMoy is not null %}
				<div class="kpi-data-item" style="border-top:1px dashed rgba(0,0,0,.1);padding-top:.3rem;margin-top:.1rem;">
					<span class="kdi-label" style="color:#2d6da6;">CGT MOY. PÉRIODE</span>
					<span class="kdi-val" style="color:var(--text-primary);">
						{{ soldeCgtMoy|number_format(0, ',', ' ') }} Mds
					</span>
				</div>
				<div class="kpi-data-item" style="padding-top:.3rem;">
					<span class="kdi-label">VARIATION CGT CUMULÉE</span>
					<span class="kdi-val">
						{% if variationCgtCumulee is not null %}
							{% if variationCgtCumulee > 10 %}
								<span style="color:#155724;">&#9650; {{ variationCgtCumulee|number_format(0,',',' ') }} Mds</span>
							{% elseif variationCgtCumulee < -10 %}
								<span style="color:#721c24;">&#9660; {{ (variationCgtCumulee)|number_format(0,',',' ') }} Mds</span>
							{% else %}
								<span style="color:#6c757d;">&approx; {{ variationCgtCumulee|number_format(0,',',' ') }} Mds</span>
							{% endif %}
						{% else %}—{% endif %}
					</span>
				</div>
				{% endif %}
			</div>
			<div class="kpi-title">🏦 Pilier 3 — Marché Monétaire</div>
		</div>

		{# ─ Pilier 4 : Budget & Trésorerie ─ #}
		<div class="kpi-card signal-{{ signalTresorerie }}">
			<span class="kpi-pill pill-{{ signalTresorerie }}">{{ pillLabels[signalTresorerie] ?? 'N/D' }}</span>
			<div class="kpi-value">
