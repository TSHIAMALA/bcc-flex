				<i class="fas fa-chart-line" style="color:#2d6da6"></i>
				Évolution Écart de Change</h3>
			<div class="chart-wrapper">
				<canvas id="chartChange"></canvas>
			</div>
		</div>

		<div class="chart-card">
			<h3>
				<i class="fas fa-globe" style="color:#2d6da6"></i>
				Réserves Internationales (Mds $)</h3>
			<div class="chart-wrapper">
				<canvas id="chartReserves"></canvas>
			</div>
		</div>

		<div class="chart-card">
			<h3>
				<i class="fas fa-tint" style="color:#2d6da6"></i>
				Avoirs Libres (Mds CDF)</h3>
			<div class="chart-wrapper">
				<canvas id="chartLiquidite"></canvas>
			</div>
		</div>

		<div class="chart-card">
			<h3>
				<i class="fas fa-balance-scale" style="color:#2d6da6"></i>
				Solde Budgétaire (Mds CDF)</h3>
			<div class="chart-wrapper">
				<canvas id="chartBudget"></canvas>
			</div>
		</div>

	</div>

	{# ── 2 Graphiques CGT (symmétrie : rangée 3 du tableau de bord) ────── #}
	{% if chartCgt is defined and chartCgt|length > 0 %}
	<div class="charts-grid">

		{# Graphique 5 : Évolution du Solde CGT #}
		<div class="chart-card">
			<h3>
				<i class="fas fa-university" style="color:#2d6da6"></i>
				Solde CGT — Évolution sur la Période (Mds CDF)</h3>
			<div class="chart-wrapper">
				<canvas id="chartCgtEvo"></canvas>
			</div>
		</div>

		{# Graphique 6 remplacé : Effet Miroir — Option A KPI cards #}
		<div class="chart-card" style="display:flex;flex-direction:column;justify-content:center;">
			<h3>
				<i class="fas fa-arrows-alt-v" style="color:#2d6da6"></i>
				Effet Miroir — CGT &amp; Avoirs Libres</h3>

			{% if soldeCgtMoy is not null %}
			{% set cgtDir = variationCgtCumulee is not null ? (variationCgtCumulee > 10 ? 'up' : (variationCgtCumulee < -10 ? 'down' : 'stable')) : 'stable' %}

			<div style="display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:14px;">

				{# — Carte CGT — #}
				{% set cgtBg    = cgtDir == 'up' ? 'rgba(21,87,36,.07)'    : (cgtDir == 'down' ? 'rgba(114,28,36,.07)'    : 'rgba(45,109,166,.07)') %}
				{% set cgtBd    = cgtDir == 'up' ? '#38a16940'              : (cgtDir == 'down' ? '#721c2440'              : '#2d6da640') %}
				{% set cgtColor = cgtDir == 'up' ? '#155724'                : (cgtDir == 'down' ? '#721c24'                : '#1e4b7a') %}
				{% set cgtArrow = cgtDir == 'up' ? '▲'                     : (cgtDir == 'down' ? '▼'                     : '≈') %}
				<div style="background:{{ cgtBg }};border:1px solid {{ cgtBd }};border-radius:12px;padding:16px 14px;">
					<div style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#64748b;margin-bottom:6px;">Solde CGT moy. période</div>
					<div style="font-size:1.5rem;font-weight:900;color:{{ cgtColor }};line-height:1.1;">
						{{ cgtArrow }} {{ soldeCgtMoy|number_format(0,',',' ') }} Mds
					</div>
					{% if variationCgtCumulee is not null %}
					<div style="font-size:.75rem;margin-top:6px;font-weight:600;color:{{ cgtColor }};">
						Δ période : {% if variationCgtCumulee > 0 %}+{% endif %}{{ variationCgtCumulee|number_format(0,',',' ') }} Mds
					</div>
					{% endif %}
					<div style="font-size:.65rem;color:#94a3b8;margin-top:4px;">Compte Général du Trésor</div>
				</div>

				{# — Carte Avoirs Libres — #}
				{% set avVal   = avLibresMoy %}
				{% set avSig   = avVal > 1200 ? 'red' : (avVal > 800 ? 'orange' : 'green') %}
				{% set avBg    = avSig == 'red' ? 'rgba(197,48,48,.07)'  : (avSig == 'orange' ? 'rgba(221,107,32,.07)'  : 'rgba(56,161,105,.07)') %}
				{% set avBd    = avSig == 'red' ? '#c5303040'            : (avSig == 'orange' ? '#dd6b2040'             : '#38a16940') %}
				{% set avColor = avSig == 'red' ? '#721c24'              : (avSig == 'orange' ? '#8a4700'               : '#155724') %}
				{% set avArrow = cgtDir == 'up' ? '▼' : (cgtDir == 'down' ? '▲' : '≈') %}
				<div style="background:{{ avBg }};border:1px solid {{ avBd }};border-radius:12px;padding:16px 14px;">
					<div style="font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:.5px;color:#64748b;margin-bottom:6px;">Avoirs libres moy. période</div>
					<div style="font-size:1.5rem;font-weight:900;color:{{ avColor }};line-height:1.1;">
						{{ avArrow }} {{ avVal is not null ? avVal|number_format(0,',',' ') : '—' }} Mds
					</div>
					<div style="font-size:.75rem;margin-top:6px;font-weight:600;color:{{ avColor }};">
						{% if avSig == 'red' %}⚠ Surliquidité critique{% elseif avSig == 'orange' %}⚠ Zone de vigilance{% else %}✓ Niveau maîtrisé{% endif %}
					</div>
					<div style="font-size:.65rem;color:#94a3b8;margin-top:4px;">Seuil alerte 800 / 1 200 Mds</div>
				</div>

			</div>

			{# — Banderole interprétation — #}
			{% if cgtDir == 'up' %}
			<div style="background:rgba(21,87,36,.08);border-left:4px solid #38a169;border-radius:8px;padding:10px 14px;font-size:.8rem;line-height:1.5;">
				<strong style="color:#155724;">📉 Absorption en cours</strong>
				<span style="color:#1e4b7a;margin-left:6px;">— Le CGT capte des liquidités. Pression baissière prévisible sur les avoirs libres bancaires.</span>
			</div>
			{% elseif cgtDir == 'down' %}
			<div style="background:rgba(114,28,36,.08);border-left:4px solid #c53030;border-radius:8px;padding:10px 14px;font-size:.8rem;line-height:1.5;">
				<strong style="color:#721c24;">💧 Injection de liquidités</strong>
				<span style="color:#1e4b7a;margin-left:6px;">— Le CGT restitue des fonds. Pression haussière sur les avoirs libres et risque de surliquidité.</span>
			</div>
			{% else %}
			<div style="background:rgba(45,109,166,.06);border-left:4px solid #2d6da6;border-radius:8px;padding:10px 14px;font-size:.8rem;line-height:1.5;">
				<strong style="color:#1e4b7a;">≈ Position stable</strong>
				<span style="color:#64748b;margin-left:6px;">— Variation CGT ≤ 10 Mds. Aucun effet miroir significatif détecté sur la période.</span>
			</div>
			{% endif %}

			{% else %}
			<div style="text-align:center;padding:2rem;color:#94a3b8;font-size:.9rem;">
				<i class="fas fa-university"></i><br>Aucune donnée CGT sur la période
			</div>
			{% endif %}
		</div>


	</div>
	{% endif %}

	{# ── Tableau synthèse détaillé ─────────────────────────────────────────── #}
	<div class="summary-card">
		<h3>
			<i class="fas fa-table" style="color:#2d6da6; margin-right:.4rem"></i>Synthèse des Indicateurs sur la Période</h3>
		<table class="summary-table">
			<thead>
				<tr>
					<th>Pilier</th>
					<th>Indicateur</th>
					<th>Moy. Période</th>
					<th>Min</th>
					<th>Max</th>
					<th>Signal</th>
					<th style="text-align:center">Taux Directeur</th>
				</tr>
			</thead>
			<tbody>
				<tr>
					<td style="font-weight:600;color:#1e4b7a">🏦 Change</td>
					<td>Écart indicatif/parallèle (%)</td>
					<td>
						{% if ecartMoy is not null %}
							{{ ecartMoy|number_format(2,',',' ') }}
							%{% else %}—
						{% endif %}
					</td>
					<td>
						{% if ecartMin is not null %}
							{{ ecartMin|number_format(2,',',' ') }}
							%{% else %}—
						{% endif %}
					</td>
					<td>
						{% if ecartMax is not null %}
							{{ ecartMax|number_format(2,',',' ') }}
							%{% else %}—
						{% endif %}
					</td>
					<td>
						<span class="badge badge-{{ signalChange }}">{{ pillLabels[signalChange] ?? 'N/D' }}</span>
					</td>
					<td style="text-align:center; font-size:.78rem; color:#666">
						{% if ecartMoy is not null and ecartMoy <= 2 %}✅ Favorable{% elseif ecartMoy is not null and ecartMoy <= 3 %}⚠️ Prudence{% elseif ecartMoy is not null %}🛑 Bloquer baisse{% else %}—
						{% endif %}
					</td>
				</tr>
				<tr>
					<td style="font-weight:600;color:#1e4b7a">🌍 Réserves</td>
					<td>Réserves internationales (Md$)</td>
					<td>
						{% if reservesIntMoy is not null %}
							{{ (reservesIntMoy/1000)|number_format(2,',',' ') }}{% else %}—
						{% endif %}
					</td>
					<td>
						{% if reserves.reserves_int_min is defined and reserves.reserves_int_min %}
							{{ (reserves.reserves_int_min/1000)|number_format(2,',',' ') }}{% else %}—
						{% endif %}
					</td>
					<td>
						{% if reserves.reserves_int_max is defined and reserves.reserves_int_max %}
							{{ (reserves.reserves_int_max/1000)|number_format(2,',',' ') }}{% else %}—
						{% endif %}
					</td>
					<td>
						<span class="badge badge-green">🟢 Ancre</span>
					</td>
					<td style="text-align:center; font-size:.78rem; color:#666">✅ Neutre</td>
				</tr>
				<tr>
					<td style="font-weight:600;color:#1e4b7a">🏦 Marché Mon.</td>
					<td>Encours Bons BCC (Mds CDF)</td>
					<td>
						{% if encoursBonsMoy is not null %}
							{{ encoursBonsMoy|number_format(0,',',' ') }}{% else %}—
						{% endif %}
					</td>
					<td>—</td>
					<td>
						{% if encoursBcc.encours_bons_max is defined and encoursBcc.encours_bons_max %}
							{{ encoursBcc.encours_bons_max|number_format(0,',',' ') }}{% else %}—
						{% endif %}
					</td>
					<td>
						<span class="badge badge-{{ signalLiquidite }}">{{ pillLabels[signalLiquidite] ?? 'N/D' }}</span>
					</td>
					<td style="text-align:center; font-size:.78rem; color:#666">
						{% if signalLiquidite == 'red' %}🛑 Action requise{% elseif signalLiquidite == 'orange' %}⚠️ Surveiller{% else %}✅ Maîtrisée
						{% endif %}
					</td>
				</tr>
				<tr>
					<td style="font-weight:600;color:#1e4b7a">🏛️ Budget</td>
					<td>Solde trésorerie (Mds CDF)</td>
					<td>
						{% if soldeMoy is not null %}
							{{ soldeMoy|number_format(0,',',' ') }}{% else %}—
						{% endif %}
					</td>
					<td>
						{% if finances.solde_min is defined and finances.solde_min %}
							{{ finances.solde_min|number_format(0,',',' ') }}{% else %}—
						{% endif %}
					</td>
					<td>
						{% if finances.solde_max is defined and finances.solde_max %}
							{{ finances.solde_max|number_format(0,',',' ') }}{% else %}—
						{% endif %}
					</td>
					<td>
						<span class="badge badge-{{ signalTresorerie }}">{{ pillLabels[signalTresorerie] ?? 'N/D' }}</span>
					</td>
					<td style="text-align:center; font-size:.78rem; color:#666">
						{% if soldeMoy is not null and soldeMoy < -100 %}🛑 Tension{% elseif soldeMoy is not null and soldeMoy < 0 %}⚠️ Surveiller{% else %}✅ Neutre
						{% endif %}
					</td>
				</tr>
			</tbody>
		</table>
	</div>

	{# ── Note pédagogique ──────────────────────────────────────────────────── #}
	<div style="background:#fff; border-radius:14px; padding:1.4rem; box-shadow:0 2px 12px rgba(0,0,0,.07); border-left:4px solid #2d6da6; margin-bottom:1.5rem;">
		<h3 style="font-size:.92rem; font-weight:700; color:#1e4b7a; margin-bottom:.6rem;">
			<i class="fas fa-lightbulb" style="margin-right:.4rem; color:#f7e034;"></i>
			Principe de décision — Taux Directeur & Politique Monétaire
		</h3>
		<p style="font-size:.83rem; color:#555; line-height:1.65; margin:0;">
			Dans le cadre de notre écosystème monétaire pluriel, le taux directeur est avant tout un
			<strong>signal de crédibilité</strong>. Sa baisse, même en période de désinflation, peut alimenter
																        des anticipations de dépréciation si le marché parallèle n'est pas encore aligné avec
																        le taux indicatif.
			<strong>Règle opérationnelle :</strong>
			le taux ne baisse que lorsque
												        l'écart de change est stabilisé en zone verte (&lt; 2 %) ET que la surliquidité est
												        maîtrisée par la stérilisation (B-BCC). En zone orange ou rouge, le maintien du taux
												        directeur est la première ligne de défense de l'ancre nominale.
		</p>
	</div>

		{# ── Bandeau Taux Directeur ────────────────────────────────────────────── #}
	<div class="top-dashboard-grid" style="display: grid; grid-template-columns: 1fr 1.2fr; gap: 1.5rem; margin-bottom: 1.5rem; align-items: stretch;">

		<div class="signal-global-card" style="background: var(--bg-card, #fff); border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 24px rgba(0,0,0,0.06); text-align: center; display: flex; flex-direction: column; align-items: center; border: 1px solid rgba(15,23,42,0.05);">
			{% set signalMap = {green:'🟢 Normal', yellow:'🟡 Vigilance', orange:'🟠 Alerte', red:'🔴 Critique', secondary:'⚪ N/D'} %}
			{% set textMap = {green:'Normal', yellow:'Vigilance', orange:'Alerte', red:'Critique', secondary:'N/D'} %}

			{# Mapping text signal to score mathematically #}
			{% set signalScore = signalGlobal == 'red' ? 85 : (signalGlobal == 'orange' ? 65 : (signalGlobal == 'yellow' ? 45 : (signalGlobal == 'green' ? 15 : 0))) %}

			<div style="position: relative; margin-bottom: 1rem; width: 100%;">
				<div style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
					<div style="font-size:.75rem; font-weight:700; opacity:.6; text-transform:uppercase; letter-spacing:1px; color: var(--text-primary, #1f2937);">Indice de Tension Global</div>
					<button onclick="toggleItmInfo(event)" style="background:none; border:none; cursor:pointer; color: var(--text-secondary, #64748b); font-size:1rem; padding:0; display:flex;" title="Comprendre le calcul">
						<i class="fas fa-question-circle"></i>
					</button>
				</div>

				<!-- Panneau d'information masqué par défaut -->
				<div id="itmInfoPanel" style="display: none; position: absolute; z-index: 50; top: 1.8rem; left: 50%; transform: translateX(-50%); width: 280px; background: var(--bg-card, #fff); border: 1px solid rgba(15,23,42,0.1); border-radius: 12px; padding: 1.2rem; box-shadow: 0 10px 25px rgba(0,0,0,0.15); text-align: left;">
					<div style="font-size: .8rem; color: var(--text-primary); margin-bottom: .8rem; line-height: 1.4;">
						<strong>L'Indice de Tension Global</strong>
						est un indicateur composite calculé sur base de quatre paramètres pondérés :
					</div>
					<ul style="list-style-type: none; padding-left: 0; margin: 0; font-size: .75rem; color: var(--text-secondary); line-height: 1.5;">
						<li style="margin-bottom: .4rem;">
							<strong>35%</strong>
							- Écart de change indicatif / parallèle (Moy)</li>
						<li style="margin-bottom: .4rem;">
							<strong>25%</strong>
							- Surliquidité bancaire (Avoirs libres)</li>
						<li style="margin-bottom: .4rem;">
							<strong>20%</strong>
							- Réserves internationales (Moy)</li>
						<li>
							<strong>20%</strong>
							- Solde budgétaire (Moy)</li>
					</ul>
					<button onclick="toggleItmInfo(event)" style="margin-top: 1.2rem; width: 100%; padding: .4rem; border: none; border-radius: 6px; background: rgba(15,23,42,0.05); cursor: pointer; color: var(--text-primary); font-size: .75rem; font-weight: 600; transition: background 0.2s;">Fermer</button>
				</div>
			</div>

			<div class="signal-global-gauge" style="margin:0 auto; width:100%; max-width:320px; height:auto;">
				<svg
					viewbox="0 0 200 130" style="width:100%; height:100%; display:block;">
					<!-- Definitions for gradients -->
					<defs>
						<linearGradient id="gGreen" x1="0%" y1="0%" x2="100%">
							<stop offset="0%" stop-color="#10b981"/>
							<stop offset="100%" stop-color="#34d399"/>
						</linearGradient>
						<linearGradient id="gYellow" x1="0%" y1="0%" x2="100%">
							<stop offset="0%" stop-color="#84cc16"/>
							<stop offset="100%" stop-color="#f59e0b"/>
						</linearGradient>
						<linearGradient id="gOrange" x1="0%" y1="0%" x2="100%">
							<stop offset="0%" stop-color="#f59e0b"/>
							<stop offset="100%" stop-color="#f97316"/>
						</linearGradient>
						<linearGradient id="gRed" x1="0%" y1="0%" x2="100%">
							<stop offset="0%" stop-color="#f97316"/>
							<stop offset="100%" stop-color="#ef4444"/>
						</linearGradient>
					</defs>
					<path d="M 20 105 A 80 80 0 0 1 50 45" fill="none" stroke="url(#gGreen)" stroke-width="18" stroke-linecap="butt"/>
					<path d="M 52 43 A 80 80 0 0 1 100 25" fill="none" stroke="url(#gYellow)" stroke-width="18" stroke-linecap="butt"/>
					<path d="M 102 25 A 80 80 0 0 1 148 43" fill="none" stroke="url(#gOrange)" stroke-width="18" stroke-linecap="butt"/>
					<path d="M 150 45 A 80 80 0 0 1 180 105" fill="none" stroke="url(#gRed)" stroke-width="18" stroke-linecap="butt"/>
					<g transform="rotate({{ -90 + (signalScore * 1.8) }}, 100, 105)">
						<polygon points="100,40 96,105 104,105" fill="var(--text-primary, #1f2937)"/>
						<circle cx="100" cy="105" r="10" fill="var(--text-primary, #1f2937)"/>
						<circle cx="100" cy="105" r="6" fill="var(--bg-card, #fff)"/>
					</g>
				</svg>
			</div>

			<div style="margin-top:-5px; font-weight:800; font-size:1.3rem; color: var(--text-primary, #1f2937);">
				{{ signalMap[signalGlobal]|slice(0, 1) }}
				{{ textMap[signalGlobal] ?? 'N/D' }}
			</div>

			{# ── Indicateurs clés ── #}
			{% set signalColors = {'green': '#10b981', 'yellow': '#ecc94b', 'orange': '#f59e0b', 'red': '#ef4444', 'secondary': '#94a3b8'} %}
			{% set signalBg = {'green': 'rgba(16,185,129,.12)', 'yellow': 'rgba(236,201,75,.15)', 'orange': 'rgba(245,158,11,.15)', 'red': 'rgba(239,68,68,.12)', 'secondary': 'rgba(148,163,184,.12)'} %}
			{% set indicators = [
				{'label': 'Écart de change',         'val': ecartMoy is not null ? ecartMoy|number_format(2, ',', ' ') ~ ' %' : 'N/D',                                   'signal': signalChange},
				{'label': 'Réserves int.',            'val': reservesIntMoy ? (reservesIntMoy/1000)|number_format(2, ',', ' ') ~ ' Md$' : 'N/D',                          'signal': signalReserves ?? 'green'},
				{'label': 'Encours Bons BCC (Moy)',   'val': encoursBonsMoy ? encoursBonsMoy|number_format(0, ',', ' ') ~ ' Mds' : 'N/D',                                       'signal': signalLiquidite},
				{'label': 'Solde budgétaire',         'val': soldeMoy is not null ? soldeMoy|number_format(0, ',', ' ') ~ ' Mds' : 'N/D',                                 'signal': signalTresorerie}
			] %}

			<div style="width:100%; margin-top:1.2rem; display:grid; grid-template-columns:1fr 1fr; gap:.6rem;">
				{% for ind in indicators %}
				<div style="background:{{ signalBg[ind.signal] ?? 'rgba(148,163,184,.12)' }}; border:1px solid {{ signalColors[ind.signal] ?? '#94a3b8' }}33; border-left:3px solid {{ signalColors[ind.signal] ?? '#94a3b8' }}; border-radius:8px; padding:.55rem .75rem; display:flex; flex-direction:column; gap:.2rem;">
					<span style="font-size:.68rem; font-weight:600; color:var(--text-secondary,#64748b); text-transform:uppercase; letter-spacing:.4px; line-height:1.2;">{{ ind.label }}</span>
					<span style="font-size:.95rem; font-weight:800; color:{{ signalColors[ind.signal] ?? '#94a3b8' }}; font-variant-numeric:tabular-nums;">{{ ind.val }}</span>
				</div>
				{% endfor %}
			</div>


		</div>

		<div class="taux-banner {{ recoTaux.classe }}" style="margin-bottom: 0;">
			<div>
				<div class="taux-label">Taux Directeur BCC Actuel</div>
				<div class="taux-gauge">{{ tauxDirecteur|number_format(1, ',', ' ') }} %</div>
				{% if tauxDirecteurPrec != tauxDirecteur %}
					<div style="font-size:.78rem; margin-top:.25rem; opacity:.65;">
						{% if tauxDirecteur > tauxDirecteurPrec %}▲{% else %}▼{% endif %}
						Précédent : {{ tauxDirecteurPrec|number_format(1, ',', ' ') }} %
					</div>
				{% else %}
					<div style="font-size:.78rem; margin-top:.25rem; opacity:.65;">→ Inchangé</div>
				{% endif %}
			</div>
			<div style="flex:1; min-width:200px;">
				<div class="taux-reco-label">{{ recoTaux.emoji }} Recommandation : {{ recoTaux.action }}</div>
				<div style="font-weight:600; margin-bottom:.4rem; font-size:.92rem;">{{ recoTaux.label }}</div>
				<div class="taux-reco-justif">{{ recoTaux.justification }}</div>
			</div>
		</div>

	</div>
	<style>
		@media(max-width: 900px) {
			.signal-global-card {
				grid-column: span 1;
			}
			.taux-banner {
				grid-column: span 1;
			}
			.top-dashboard-grid {
				grid-template-columns: 1fr !important;
			}
		}
	</style>

{% endblock %}

{% block javascripts %}
	<script>
		// ── Données graphiques (préparées par le controller PHP) ──────────────────
const evolutionChange = {{ chartChange|json_encode|raw }};
const evolutionReserves = {{ chartReserves|json_encode|raw }};
const evolutionFinances = {{ chartFinances|json_encode|raw }};

Chart.defaults.font.family = 'Inter, sans-serif';
Chart.defaults.font.size = 11;

const SEUIL_ORANGE = 3.0;
const SEUIL_ROUGE = 5.0;
const TAUX_DIR = {{ tauxDirecteur|json_encode|raw }};

// Couleur signal
function ecartColor(v) {
if (v === null) 
return 'rgba(180,180,180,.5)';



if (v > SEUIL_ROUGE) 
return 'rgba(197,48,48,.6)';



if (v > SEUIL_ORANGE) 
return 'rgba(221,107,32,.6)';



if (v > 2) 
return 'rgba(214,158,46,.6)';



return 'rgba(56,161,105,.6)';
}

// ── Graphique 1 : Écart change ───────────────────────────────────────────
if (evolutionChange.length > 0) {
const ctx1 = document.getElementById('chartChange').getContext('2d');
const ecartData = evolutionChange.map(r => r.ecart);
new Chart(ctx1, {
type: 'line',
data: {
labels: evolutionChange.map(r => r.date),
datasets: [
{
label: 'Écart % indicatif/parallèle',
data: ecartData,
borderColor: ecartData.map(ecartColor),
backgroundColor: 'rgba(45,109,166,.08)',
borderWidth: 2,
pointRadius: 3,
tension: .35,
fill: true,
segment: {
borderColor: ctx => {
const v = ctx.p1.parsed.y;
if (v > SEUIL_ROUGE) 
return 'rgba(197,48,48,.9)';



if (v > SEUIL_ORANGE) 
return 'rgba(221,107,32,.9)';



if (v > 2) 
return 'rgba(214,158,46,.9)';



return 'rgba(56,161,105,.9)';
}
}
}
]
},
options: {
responsive: true,
maintainAspectRatio: false,
plugins: {
legend: {
display: false
},
annotation: {
annotations: {
lineOrange: {
type: 'line',
yMin: SEUIL_ORANGE,
yMax: SEUIL_ORANGE,
borderColor: 'rgba(221,107,32,.5)',
borderWidth: 1,
borderDash: [
4, 4
],
label: {
content: '3%',
display: true,
font: {
size: 9
}
}
},
lineRouge: {
type: 'line',
yMin: SEUIL_ROUGE,
yMax: SEUIL_ROUGE,
borderColor: 'rgba(197,48,48,.5)',
borderWidth: 1,
borderDash: [
4, 4
],
label: {
content: '5%',
display: true,
font: {
size: 9
}
}
}
}
}
},
scales: {
y: {
grid: {
color: 'rgba(0,0,0,.05)'
},
ticks: {
callback: v => v + ' %'
}
},
x: {
grid: {
display: false
},
ticks: {
maxTicksLimit: 12,
maxRotation: 45
}
}
}
}
});
} else {
document.getElementById('chartChange').parentElement.innerHTML = '<div class="no-data"><i class="fas fa-chart-line"></i>Aucune donnée de change sur la période</div>';
}

// ── Graphique 2 : Réserves ──────────────────────────────────────────────
if (evolutionReserves.length > 0) {
const ctx2 = document.getElementById('chartReserves').getContext('2d');
new Chart(ctx2, {
type: 'line',
data: {
labels: evolutionReserves.map(r => r.date),
datasets: [
{
label: 'Réserves int. (Md$)',
data: evolutionReserves.map(r => r.res),
borderColor: '#2d6da6',
backgroundColor: 'rgba(45,109,166,.1)',
borderWidth: 2,
pointRadius: 2,
tension: .35,
fill: true

}
]
},
options: {
responsive: true,
maintainAspectRatio: false,
plugins: {
legend: {
display: false
}
},
scales: {
y: {
grid: {
color: 'rgba(0,0,0,.05)'
},
ticks: {
callback: v => v + ' Md$'
}
},
x: {
grid: {
display: false
},
ticks: {
maxTicksLimit: 12,
maxRotation: 45
}
}
}
}
});
} else {
document.getElementById('chartReserves').parentElement.innerHTML = '<div class="no-data"><i class="fas fa-globe"></i>Aucune donnée de réserves</div>';
}

// ── Graphique 3 : Avoirs libres ──────────────────────────────────────────
const avData = evolutionReserves.filter(r => r.av !== null);
if (avData.length > 0) {
const ctx3 = document.getElementById('chartLiquidite').getContext('2d');
new Chart(ctx3, {
type: 'bar',
data: {
labels: avData.map(r => r.date),
datasets: [
{
label: 'Avoirs libres (Mds CDF)',
data: avData.map(r => r.av),
backgroundColor: avData.map(r => r.av > 1200 ? 'rgba(197,48,48,.65)' : r.av > 800 ? 'rgba(221,107,32,.65)' : 'rgba(56,161,105,.65)'),
borderRadius: 3
}
]
},
options: {
responsive: true,
maintainAspectRatio: false,
plugins: {
legend: {
display: false
}
},
scales: {
y: {
grid: {
color: 'rgba(0,0,0,.05)'
}
},
x: {
grid: {
display: false
},
ticks: {
maxTicksLimit: 12,
maxRotation: 45
}
}
}
}
});
} else {
document.getElementById('chartLiquidite').parentElement.innerHTML = '<div class="no-data"><i class="fas fa-tint"></i>Aucune donnée de liquidité</div>';
}

// ── Graphique 4 : Solde budgétaire ──────────────────────────────────────
const soldeData = evolutionFinances.filter(r => r.solde !== null);
if (soldeData.length > 0) {
const ctx4 = document.getElementById('chartBudget').getContext('2d');
new Chart(ctx4, {
type: 'bar',
data: {
labels: soldeData.map(r => r.date),
datasets: [
{
label: 'Solde budgétaire (Mds CDF)',
data: soldeData.map(r => r.solde),
backgroundColor: soldeData.map(r => r.solde < -100 ? 'rgba(197,48,48,.65)' : r.solde < 0 ? 'rgba(214,158,46,.65)' : 'rgba(56,161,105,.65)'),
borderRadius: 3
}
]
},
options: {
responsive: true,
maintainAspectRatio: false,
plugins: {
legend: {
display: false
}
},
scales: {
y: {
grid: {
color: 'rgba(0,0,0,.05)'
},
ticks: {
callback: v => v + ' M'
}
},
x: {
grid: {
display: false
},
ticks: {
maxTicksLimit: 12,
maxRotation: 45
}
}
}
}
});
} else {
document.getElementById('chartBudget').parentElement.innerHTML = '<div class="no-data"><i class="fas fa-balance-scale"></i>Aucune donnée budgétaire</div>';
}

// ── Graphique 5 : Évolution Solde CGT ─────────────────────────────────
const evolutionCgt = {{ chartCgt|default([])|json_encode|raw }};

if (evolutionCgt.length > 0) {
    const elCgtEvo = document.getElementById('chartCgtEvo');
    if (elCgtEvo) {
        const ctx5 = elCgtEvo.getContext('2d');
        const cgtVals = evolutionCgt.map(r => r.cgt);
        new Chart(ctx5, {
            type: 'line',
            data: {
                labels: evolutionCgt.map(r => r.date),
                datasets: [{
                    label: 'Solde CGT (Mds CDF)',
                    data: cgtVals,
                    borderColor: '#2d6da6',
                    backgroundColor: 'rgba(45,109,166,.1)',
                    borderWidth: 2.5,
                    pointRadius: 3,
                    tension: .35,
                    fill: true
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: {
                    y: {
                        grid: { color: 'rgba(0,0,0,.05)' },
                        ticks: { callback: v => v + ' Mds' }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { maxTicksLimit: 12, maxRotation: 45 }
                    }
                }
            }
        });
    }
} else {
    const el = document.getElementById('chartCgtEvo');
    if (el) el.parentElement.innerHTML = '<div class="no-data"><i class="fas fa-university"></i>Aucune donnée CGT sur la période</div>';
}

// ── Graphique 6 : Effet Miroir CGT & Avoirs Libres ────────────────────
if (evolutionCgt.length > 0) {
    const elMiroir = document.getElementById('chartCgtMiroir');
    if (elMiroir) {
        const ctx6 = elMiroir.getContext('2d');
        const cgtData = evolutionCgt.filter(r => r.cgt !== null);
        new Chart(ctx6, {
            type: 'bar',
            data: {
                labels: cgtData.map(r => r.date),
                datasets: [
                    {
                        type: 'line',
                        label: 'Solde CGT (Mds CDF)',
                        data: cgtData.map(r => r.cgt),
                        borderColor: '#2d6da6',
                        backgroundColor: 'transparent',
                        borderWidth: 2.5,
                        pointRadius: 2,
                        tension: .35,
                        yAxisID: 'yCgt'
                    },
                    {
                        type: 'bar',
                        label: 'Avoirs Libres (Mds CDF)',
                        data: cgtData.map(r => r.av),
                        backgroundColor: cgtData.map(r =>
                            r.av > 1200 ? 'rgba(197,48,48,.55)' :
                            r.av > 800  ? 'rgba(221,107,32,.55)' :
                                          'rgba(56,161,105,.55)'
                        ),
                        borderRadius: 3,
                        maxBarThickness: 60,
                        yAxisID: 'yAv'
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                interaction: { mode: 'index', intersect: false },
                plugins: {
                    legend: {
                        display: true,
                        position: 'top',
                        labels: { boxWidth: 12, font: { size: 10 } }
                    }
                },
                scales: {
                    yCgt: {
                        type: 'linear',
                        position: 'left',
                        grid: { color: 'rgba(0,0,0,.05)' },
                        ticks: { callback: v => v + ' Mds', font: { size: 9 } }
                    },
                    yAv: {
                        type: 'linear',
                        position: 'right',
                        grid: { drawOnChartArea: false },
                        ticks: { callback: v => v + ' Mds', font: { size: 9 } }
                    },
                    x: {
                        grid: { display: false },
                        ticks: { maxTicksLimit: 12, maxRotation: 45 }
                    }
                }
            }
        });
    }
} else {
    const el = document.getElementById('chartCgtMiroir');
    if (el) el.parentElement.innerHTML = '<div class="no-data"><i class="fas fa-chart-area"></i>Aucune donnée CGT pour l\'effet miroir</div>';
}

// ── Info ITM ─────────────────────────────────────────────────────────────
function toggleItmInfo(e) {
if (e) 
e.stopPropagation();

const panel = document.getElementById('itmInfoPanel');
if (panel) {
panel.style.display = panel.style.display === 'none' ? 'block' : 'none';
}
}

// Fermer le panneau si on clique en dehors
document.addEventListener('click', function (e) {
const panel = document.getElementById('itmInfoPanel');
if (panel && panel.style.display === 'block') {
const btn = e.target.closest('button[onclick="toggleItmInfo(event)"]');
if (! panel.contains(e.target) && ! btn) {
panel.style.display = 'none';
}
}
});
	</script>
{% endblock %}
