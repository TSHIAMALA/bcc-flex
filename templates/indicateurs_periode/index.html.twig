{% extends 'base.html.twig' %}

{% block title %}Indicateurs de Période
{% endblock %}

{% block header_title %}Indicateurs de Période
{% endblock %}
{% block header_subtitle %}Agrégats & Orientation Politique Monétaire
{% endblock %}

{% block stylesheets %}
	<style>
		/* ── Tone de page ─────────────────────────────────────────────────────── */
		.page-content {
			background: #f0f4f8;
		}
		[data-theme="dark"] .page-content,
		body.dark-mode .page-content {
			background: #0f172a;
		}

		/* ── Sélecteur de période ────────────────────────────────────────────── */
		.periode-card {
			background: linear-gradient(135deg, #1e4b7a 0%, #2d6da6 100%);
			border-radius: 16px;
			padding: 1.5rem 2rem;
			color: #fff;
			display: flex;
			align-items: center;
			flex-wrap: wrap;
			gap: 1rem;
			margin-bottom: 1.5rem;
			box-shadow: 0 4px 20px rgba(30, 75, 122, 0.35);
		}
		.periode-card label {
			font-weight: 600;
			font-size: 0.85rem;
			letter-spacing: 0.04em;
			opacity: .85;
		}
		.periode-card input[type="date"] {
			background: rgba(255, 255, 255, 0.15);
			border: 1px solid rgba(255, 255, 255, 0.35);
			color: #fff;
			border-radius: 8px;
			padding: 0.45rem 0.9rem;
			font-size: 0.9rem;
			outline: none;
			transition: background 0.2s;
		}
		.periode-card input[type="date"]:focus {
			background: rgba(255, 255, 255, 0.25);
		}
		.periode-card input[type="date"]::-webkit-calendar-picker-indicator {
			filter: invert(1);
		}
		.btn-appliquer {
			background: #f7e034;
			color: #1e4b7a;
			font-weight: 700;
			border: none;
			border-radius: 8px;
			padding: 0.5rem 1.4rem;
			cursor: pointer;
			font-size: 0.9rem;
			transition: all 0.2s;
		}
		.btn-appliquer:hover {
			background: #ffe900;
			transform: translateY(-1px);
		}

		.btn-export {
			background: rgba(255, 255, 255, 0.18);
			color: #fff;
			font-weight: 600;
			border: 1px solid rgba(255, 255, 255, 0.4);
			border-radius: 8px;
			padding: 0.5rem 1.2rem;
			cursor: pointer;
			font-size: 0.85rem;
			text-decoration: none;
			transition: all 0.2s;
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
		}
		.btn-export:hover {
			background: rgba(255, 255, 255, 0.3);
			color: #fff;
		}

		/* ── Bandeau Taux Directeur ──────────────────────────────────────────── */
		.taux-banner {
			border-radius: 16px;
			padding: 1.6rem 2rem;
			margin-bottom: 1.5rem;
			display: flex;
			align-items: flex-start;
			justify-content: space-between;
			gap: 1.5rem;
			flex-wrap: wrap;
			box-shadow: 0 4px 24px rgba(0, 0, 0, 0.12);
		}
		.taux-banner.success {
			background: linear-gradient(135deg,#d4edda,#c3e6cb);
			border-left: 5px solid #38a169;
		}
		.taux-banner.info {
			background: linear-gradient(135deg,#cfe2ff,#b6d4fe);
			border-left: 5px solid #4a89dc;
		}
		.taux-banner.warning {
			background: linear-gradient(135deg,#fff3cd,#ffeaa7);
			border-left: 5px solid #dd6b20;
		}
		.taux-banner.danger {
			background: linear-gradient(135deg,#f8d7da,#f5c6cb);
			border-left: 5px solid #c53030;
		}
		.taux-banner.secondary {
			background: linear-gradient(135deg,#e9ecef,#dee2e6);
			border-left: 5px solid #adb5bd;
		}

		.taux-gauge {
			font-size: 3.2rem;
			font-weight: 800;
			line-height: 1;
			color: #1e4b7a;
		}
		.taux-label {
			font-size: 0.78rem;
			text-transform: uppercase;
			letter-spacing: 0.06em;
			opacity: .7;
			font-weight: 600;
		}
		.taux-reco-label {
			font-size: 1.25rem;
			font-weight: 700;
			margin-bottom: 0.25rem;
		}
		.taux-reco-justif {
			font-size: 0.88rem;
			line-height: 1.55;
			opacity: .85;
			max-width: 65ch;
		}

		/* ── KPI Cards ──────────────────────────────────────────────────────── */
		.kpi-grid {
			display: grid;
			grid-template-columns: repeat(4, 1fr);
			gap: 1rem;
			margin-bottom: 1.5rem;
		}
		@media(max-width: 1100px) {
			.kpi-grid {
				grid-template-columns: repeat(2, 1fr);
			}
		}
		@media(max-width: 600px) {
			.kpi-grid {
				grid-template-columns: 1fr;
			}
		}
		.kpi-card {
			background: var(--bg-card);
			border-radius: 14px;
			padding: 1.25rem 1.5rem 1.35rem;
			box-shadow: 0 2px 14px rgba(0, 0, 0, 0.07);
			border-top: 4px solid rgba(0, 0, 0, 0.08);
			transition: transform 0.18s, box-shadow 0.18s;
			display: flex;
			flex-direction: column;
			gap: 0;
		}
		.kpi-card:hover {
			transform: translateY(-3px);
			box-shadow: 0 8px 24px rgba(0, 0, 0, 0.11);
		}
		.kpi-card.signal-green {
			border-top-color: #38a169;
		}
		.kpi-card.signal-yellow {
			border-top-color: #d69e2e;
		}
		.kpi-card.signal-orange {
			border-top-color: #dd6b20;
		}
		.kpi-card.signal-red {
			border-top-color: #c53030;
		}
		.kpi-card.signal-secondary {
			border-top-color: #adb5bd;
		}
		/* Pill signal */
		.kpi-pill {
			display: inline-block;
			font-size: 0.68rem;
			font-weight: 700;
			letter-spacing: 0.05em;
			padding: 0.16rem 0.52rem;
			border-radius: 20px;
			margin-bottom: 0.55rem;
			width: fit-content;
		}
		.pill-green {
			background: #d4edda;
			color: #155724;
		}
		.pill-yellow {
			background: #fff3cd;
			color: #856404;
		}
		.pill-orange {
			background: #ffe5cc;
			color: #8a4700;
		}
		.pill-red {
			background: #f8d7da;
			color: #721c24;
		}
		.pill-secondary {
			background: #e9ecef;
			color: #6c757d;
		}
		/* Valeur principale */
		.kpi-value {
			font-size: 2rem;
			font-weight: 800;
			color: var(--text-primary);
			line-height: 1.05;
			letter-spacing: -0.02em;
		}
		.kpi-subvalue {
			font-size: 0.75rem;
			color: var(--text-secondary);
			margin-top: 0.18rem;
			font-weight: 500;
		}
		/* Titre pilier */
		.kpi-title {
			font-size: 0.78rem;
			font-weight: 700;
			color: var(--text-primary);
			margin-top: 0.9rem;
			padding-top: 0.7rem;
			border-top: 1px solid rgba(0, 0, 0, 0.08);
			display: flex;
			align-items: center;
			gap: 0.3rem;
		}
		/* Mini-grille de sous-données */
		.kpi-data {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.28rem 0.5rem;
			margin-top: 0.6rem;
		}
		.kpi-data-item {
			display: flex;
			flex-direction: column;
		}
		.kdi-label {
			font-size: 0.63rem;
			font-weight: 600;
			color: var(--text-secondary);
			letter-spacing: 0.04em;
			text-transform: uppercase;
			white-space: nowrap;
		}
		.kdi-val {
			font-size: 0.82rem;
			font-weight: 700;
			color: var(--text-primary);
			white-space: nowrap;
			overflow: hidden;
			text-overflow: ellipsis;
		}

		/* ── Graphiques ─────────────────────────────────────────────────────── */
		.charts-grid {
			display: grid;
			grid-template-columns: repeat(auto-fill, minmax(440px, 1fr));
			gap: 1.2rem;
			margin-bottom: 1.5rem;
		}
		.chart-card {
			background: var(--bg-card);
			border-radius: 14px;
			padding: 1.2rem 1.4rem;
			box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
		}
		.chart-card h3 {
			font-size: 0.9rem;
			font-weight: 700;
			color: var(--text-primary);
			margin-bottom: 1rem;
			display: flex;
			align-items: center;
			gap: 0.4rem;
		}
		.chart-wrapper {
			position: relative;
			height: 220px;
		}

		/* ── Tableau résumé ─────────────────────────────────────────────────── */
		.summary-card {
			background: var(--bg-card);
			border-radius: 14px;
			padding: 1.4rem;
			box-shadow: 0 2px 12px rgba(0, 0, 0, 0.07);
			margin-bottom: 1.5rem;
			overflow-x: auto;
		}
		.summary-card h3 {
			font-size: 0.95rem;
			font-weight: 700;
			color: var(--text-primary);
			margin-bottom: 1rem;
		}
		.summary-table {
			width: 100%;
			border-collapse: collapse;
			font-size: 0.83rem;
		}
		.summary-table th {
			background: #1e4b7a;
			color: #fff;
			padding: 0.55rem 0.8rem;
			text-align: left;
			font-size: 0.78rem;
			font-weight: 600;
			letter-spacing: 0.04em;
			white-space: nowrap;
		}
		.summary-table td {
			padding: 0.5rem 0.8rem;
			border-bottom: 1px solid rgba(0, 0, 0, 0.08);
			white-space: nowrap;
		}
		.summary-table tr:hover td {
			background: rgba(0, 0, 0, 0.04);
		}

		/* signal inline badges */
		.badge {
			padding: 0.22rem 0.55rem;
			border-radius: 20px;
			font-size: 0.7rem;
			font-weight: 700;
			display: inline-block;
		}
		.badge-green {
			background: #d4edda;
			color: #155724;
		}
		.badge-yellow {
			background: #fff3cd;
			color: #856404;
		}
		.badge-orange {
			background: #ffe5cc;
			color: #8a4700;
		}
		.badge-red {
			background: #f8d7da;
			color: #721c24;
		}
		.badge-secondary {
			background: #e9ecef;
			color: #6c757d;
		}

		/* ── No-data ────────────────────────────────────────────────────────── */
		.no-data {
			text-align: center;
			padding: 3rem 1rem;
			color: #bbb;
			font-size: 0.95rem;
		}
		.no-data i {
			font-size: 2.5rem;
			display: block;
			margin-bottom: 0.7rem;
		}

		/* Dark mode tweaks */
		[data-theme="dark"] .summary-table th,
		body.dark-mode .summary-table th {
			background: rgba(255, 255, 255, 0.1);
			color: var(--text-secondary);
		}

		[data-theme="dark"] .summary-table tr:hover td,
		body.dark-mode .summary-table tr:hover td {
			background: rgba(255, 255, 255, 0.08);
		}

		[data-theme="dark"] .taux-banner,
		body.dark-mode .taux-banner {
			background: rgba(30, 41, 59, 0.85);
			box-shadow: 0 4px 24px rgba(0, 0, 0, 0.35);
			color: var(--text-primary);
		}

		[data-theme="dark"] .taux-banner .taux-gauge,
		body.dark-mode .taux-banner .taux-gauge {
			color: var(--text-primary);
		}

		[data-theme="dark"] .taux-banner .taux-label,
		body.dark-mode .taux-banner .taux-label,
		[data-theme="dark"] .taux-banner .taux-reco-label,
		body.dark-mode .taux-banner .taux-reco-label,
		[data-theme="dark"] .taux-banner .taux-reco-justif,
		body.dark-mode .taux-banner .taux-reco-justif {
			color: var(--text-secondary);
		}
	</style>
{% endblock %}

{% block body %}

	{# ── Sélecteur de période ──────────────────────────────────────────────── #}
	<form method="get" action="{{ path('app_indicateurs_periode') }}" class="periode-card">
		<div>
			<label>Du</label>
			<input type="date" name="dateDebut" value="{{ dateDebut }}" required>
		</div>
		<div>
			<label>Au</label>
			<input type="date" name="dateFin" value="{{ dateFin }}" required>
		</div>
		<button type="submit" class="btn-appliquer">
			<i class="fas fa-filter" style="margin-right:.35rem"></i>Appliquer
		</button>
		<a href="{{ path('app_indicateurs_periode_slide', {dateDebut: dateDebut, dateFin: dateFin}) }}" style="background:#ed8004" class="btn-export" target="_blank">
			<i class="fas fa-file-powerpoint" ;"></i>Exporter le Slide
		</a>
		<span style="margin-left:auto; opacity:.7; font-size:.82rem">
			Période :
			{{ dateDebut|date('d/m/Y') }}
			→
			{{ dateFin|date('d/m/Y') }}
			{% if change.nb_jours is defined and change.nb_jours %}
				&nbsp;·&nbsp;
				{{ change.nb_jours }}
				jours observés
			{% endif %}
		</span>
	</form>

	{# ── Bandeau Taux Directeur ────────────────────────────────────────────── #}
	<div class="top-dashboard-grid" style="display: grid; grid-template-columns: 1.2fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem; align-items: stretch;">

		<div class="taux-banner {{ recoTaux.classe }}" style="margin-bottom: 0;">
			<div>
				<div class="taux-label">Taux Directeur BCC Actuel</div>
				<div class="taux-gauge">{{ tauxDirecteur|number_format(1, ',', ' ') }}
					%</div>
				{% if tauxDirecteurPrec != tauxDirecteur %}
					<div style="font-size:.78rem; margin-top:.25rem; opacity:.65;">
						{% if tauxDirecteur > tauxDirecteurPrec %}▲{% else %}▼
						{% endif %}
						Précédent :
						{{ tauxDirecteurPrec|number_format(1, ',', ' ') }}
						%
					</div>
				{% else %}
					<div style="font-size:.78rem; margin-top:.25rem; opacity:.65;">→ Inchangé</div>
				{% endif %}
			</div>
			<div style="flex:1; min-width:200px;">
				<div class="taux-reco-label">{{ recoTaux.emoji }}
					Recommandation :
					{{ recoTaux.action }}</div>
				<div style="font-weight:600; margin-bottom:.4rem; font-size:.92rem;">{{ recoTaux.label }}</div>
				<div class="taux-reco-justif">{{ recoTaux.justification }}</div>
			</div>
		</div>

		<div class="signal-global-card" style="background: var(--bg-card, #fff); border-radius: 16px; padding: 1.5rem; box-shadow: 0 4px 24px rgba(0,0,0,0.06); text-align: center; display: flex; flex-direction: column; align-items: center; border: 1px solid rgba(15,23,42,0.05);">
			{% set signalMap = {green:'🟢 Normal', yellow:'🟡 Vigilance', orange:'🟠 Alerte', red:'🔴 Critique', secondary:'⚪ N/D'} %}
			{% set textMap = {green:'Normal', yellow:'Vigilance', orange:'Alerte', red:'Critique', secondary:'N/D'} %}

			{# Mapping text signal to score mathematically #}
			{% set signalScore = signalGlobal == 'red' ? 85 : (signalGlobal == 'orange' ? 65 : (signalGlobal == 'yellow' ? 45 : (signalGlobal == 'green' ? 15 : 0))) %}

			<div style="position: relative; margin-bottom: 1rem; width: 100%;">
				<div style="display: flex; align-items: center; justify-content: center; gap: 0.5rem;">
					<div style="font-size:.75rem; font-weight:700; opacity:.6; text-transform:uppercase; letter-spacing:1px; color: var(--text-primary, #1f2937);">Indice de Tension Global</div>
					<button onclick="toggleItmInfo(event)" style="background:none; border:none; cursor:pointer; color: var(--text-secondary, #64748b); font-size:1rem; padding:0; display:flex;" title="Comprendre le calcul">
						<i class="fas fa-question-circle"></i>
					</button>
				</div>

				<!-- Panneau d'information masqué par défaut -->
				<div id="itmInfoPanel" style="display: none; position: absolute; z-index: 50; top: 1.8rem; left: 50%; transform: translateX(-50%); width: 280px; background: var(--bg-card, #fff); border: 1px solid rgba(15,23,42,0.1); border-radius: 12px; padding: 1.2rem; box-shadow: 0 10px 25px rgba(0,0,0,0.15); text-align: left;">
					<div style="font-size: .8rem; color: var(--text-primary); margin-bottom: .8rem; line-height: 1.4;">
						<strong>L'Indice de Tension Global</strong>
						est un indicateur composite calculé sur base de quatre paramètres pondérés :
					</div>
					<ul style="list-style-type: none; padding-left: 0; margin: 0; font-size: .75rem; color: var(--text-secondary); line-height: 1.5;">
						<li style="margin-bottom: .4rem;">
							<strong>35%</strong>
							- Écart de change indicatif / parallèle (Moy)</li>
						<li style="margin-bottom: .4rem;">
							<strong>25%</strong>
							- Surliquidité bancaire (Avoirs libres)</li>
						<li style="margin-bottom: .4rem;">
							<strong>20%</strong>
							- Réserves internationales (Moy)</li>
						<li>
							<strong>20%</strong>
							- Solde budgétaire (Moy)</li>
					</ul>
					<button onclick="toggleItmInfo(event)" style="margin-top: 1.2rem; width: 100%; padding: .4rem; border: none; border-radius: 6px; background: rgba(15,23,42,0.05); cursor: pointer; color: var(--text-primary); font-size: .75rem; font-weight: 600; transition: background 0.2s;">Fermer</button>
				</div>
			</div>

			<div class="signal-global-gauge" style="margin:0 auto; width:100%; max-width:210px; height:auto;">
				<svg
					viewbox="0 0 200 130" style="width:100%; height:100%; display:block;">
					<!-- Definitions for gradients -->
					<defs>
						<linearGradient id="gGreen" x1="0%" y1="0%" x2="100%">
							<stop offset="0%" stop-color="#10b981"/>
							<stop offset="100%" stop-color="#34d399"/>
						</linearGradient>
						<linearGradient id="gYellow" x1="0%" y1="0%" x2="100%">
							<stop offset="0%" stop-color="#84cc16"/>
							<stop offset="100%" stop-color="#f59e0b"/>
						</linearGradient>
						<linearGradient id="gOrange" x1="0%" y1="0%" x2="100%">
							<stop offset="0%" stop-color="#f59e0b"/>
							<stop offset="100%" stop-color="#f97316"/>
						</linearGradient>
						<linearGradient id="gRed" x1="0%" y1="0%" x2="100%">
							<stop offset="0%" stop-color="#f97316"/>
							<stop offset="100%" stop-color="#ef4444"/>
						</linearGradient>
					</defs>
					<path d="M 20 105 A 80 80 0 0 1 50 45" fill="none" stroke="url(#gGreen)" stroke-width="18" stroke-linecap="butt"/>
					<path d="M 52 43 A 80 80 0 0 1 100 25" fill="none" stroke="url(#gYellow)" stroke-width="18" stroke-linecap="butt"/>
					<path d="M 102 25 A 80 80 0 0 1 148 43" fill="none" stroke="url(#gOrange)" stroke-width="18" stroke-linecap="butt"/>
					<path d="M 150 45 A 80 80 0 0 1 180 105" fill="none" stroke="url(#gRed)" stroke-width="18" stroke-linecap="butt"/>
					<g transform="rotate({{ -90 + (signalScore * 1.8) }}, 100, 105)">
						<polygon points="100,40 96,105 104,105" fill="var(--text-primary, #1f2937)"/>
						<circle cx="100" cy="105" r="10" fill="var(--text-primary, #1f2937)"/>
						<circle cx="100" cy="105" r="6" fill="var(--bg-card, #fff)"/>
					</g>
				</svg>
			</div>

			<div style="margin-top:-8px; font-weight:800; font-size:1.1rem; color: var(--text-primary, #1f2937);">
				{{ signalMap[signalGlobal]|slice(0, 1) }}
				{{ textMap[signalGlobal] ?? 'N/D' }}
			</div>

			<div style="width: 100%; margin-top: .8rem; text-align: left;">
				<div style="font-size: .68rem; font-weight: 700; color: var(--text-primary); margin-bottom: .5rem; opacity: .7; text-transform: uppercase; letter-spacing: .04em;">Décomposition par Composante</div>

				{% set signalColors = {'green': '#10b981', 'yellow': '#84cc16', 'orange': '#f59e0b', 'red': '#ef4444', 'secondary': '#94a3b8'} %}
				{% set indicators = [
                {'name': 'Écart de change', 'val': ecartMoy is not null ? ecartMoy|number_format(2, ',', ' ') ~ ' %' : 'N/D', 'signal': signalChange, 'score': signalChange == 'red' ? 85 : (signalChange == 'orange' ? 65 : (signalChange == 'yellow' ? 45 : 15)) },
                {'name': 'Réserves Internationales', 'val': reservesIntMoy ? (reservesIntMoy/1000)|number_format(2, ',', ' ') ~ ' Md$' : 'N/D', 'signal': signalReserves ?? 'green', 'score': (signalReserves ?? 'green') == 'red' ? 85 : ((signalReserves ?? 'green') == 'orange' ? 65 : ((signalReserves ?? 'green') == 'yellow' ? 45 : 15)) },
                {'name': 'Surliquidité bancaire', 'val': avLibresMoy ? avLibresMoy|number_format(0, ',', ' ') ~ ' Mds' : 'N/D', 'signal': signalLiquidite, 'score': signalLiquidite == 'red' ? 85 : (signalLiquidite == 'orange' ? 65 : (signalLiquidite == 'yellow' ? 45 : 15)) },
                {'name': 'Solde budgétaire', 'val': soldeMoy is not null ? soldeMoy|number_format(0, ',', ' ') ~ ' Mds' : 'N/D', 'signal': signalTresorerie, 'score': signalTresorerie == 'red' ? 85 : (signalTresorerie == 'orange' ? 65 : (signalTresorerie == 'yellow' ? 45 : 15)) }
            ] %}

				{% for ind in indicators %}
