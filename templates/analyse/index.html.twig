    font-weight: 700;
}

.bank-total-badge.vente {
    background: rgba(239, 68, 68, 0.1);
    color: #ef4444;
    border: 1px solid rgba(239, 68, 68, 0.2);
}

.bank-total-badge.achat {
    background: rgba(16, 185, 129, 0.1);
    color: #10b981;
    border: 1px solid rgba(16, 185, 129, 0.2);
}

/* Bank Summary Table */
.bank-summary-table th {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.bank-ranking-table td,
.bank-summary-table td {
    padding: 12px 14px;
    vertical-align: middle;
}

/* Dark Mode - Bank Analysis */
body.dark-mode .section-divider-line {
    background: linear-gradient(90deg, transparent, rgba(99, 102, 241, 0.4), transparent);
}

body.dark-mode .section-divider-title {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.2), rgba(139, 92, 246, 0.1));
    border-color: rgba(99, 102, 241, 0.3);
    color: #a5b4fc;
}

body.dark-mode .rank-badge {
    background: #334155;
    color: #94a3b8;
}

body.dark-mode .bank-total-badge.vente {
    background: rgba(239, 68, 68, 0.15);
    border-color: rgba(239, 68, 68, 0.3);
}

body.dark-mode .bank-total-badge.achat {
    background: rgba(16, 185, 129, 0.15);
    border-color: rgba(16, 185, 129, 0.3);
}

body.dark-mode .bank-volume-hint {
    color: #94a3b8;
}

[data-theme="dark"] .section-divider-line,
[data-theme="dark"] .section-divider-title,
[data-theme="dark"] .rank-badge,
[data-theme="dark"] .bank-total-badge.vente,
[data-theme="dark"] .bank-total-badge.achat,
[data-theme="dark"] .bank-volume-hint {
    /* Same as body.dark-mode */
}

.taux-badge.info {
    background: rgba(99, 102, 241, 0.1);
    color: #6366f1;
}
</style>

{% block javascripts %}
<script>
// Histogramme des Indicateurs
const indicateurs = {{ indicateurs|json_encode|raw }};
new Chart(document.getElementById('chartIndicateurs'), {
    type: 'bar',
    data: {
        labels: indicateurs.map(i => i.nom.split(' ').slice(0,2).join(' ')),
        datasets: [
            { label: 'Objectif', data: indicateurs.map(i => i.planifie), backgroundColor: 'rgba(0,127,255,0.3)', borderColor: '#007FFF', borderWidth: 2, borderRadius: 6 },
            { label: 'Réalisé', data: indicateurs.map(i => i.realise), backgroundColor: '#10b981', borderRadius: 6 }
        ]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: { 
            y: { beginAtZero: true, max: 100, grid: { color: 'rgba(0,0,0,0.05)' } },
            x: { grid: { display: false } }
        }
    }
});

// Donut Répartition
new Chart(document.getElementById('chartDonut'), {
    type: 'doughnut',
    data: {
        labels: indicateurs.map(i => i.nom),
        datasets: [{
            data: indicateurs.map(i => i.realise),
            backgroundColor: ['#007FFF', '#3b82f6', '#10b981', '#f59e0b', '#8b5cf6'],
            borderWidth: 0,
            hoverOffset: 10
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '65%',
        plugins: { legend: { display: false } }
    }
});

// Search functionality
document.getElementById('searchInput').addEventListener('input', function(e) {
    const filter = e.target.value.toLowerCase();
    const rows = document.querySelectorAll('#dataTable tbody tr');
    rows.forEach(row => {
        const text = row.textContent.toLowerCase();
        row.style.display = text.includes(filter) ? '' : 'none';
    });
});
// Toggle info panels
function toggleInfo(id) {
    const el = document.getElementById(id);
    if (el.style.display === 'none' || el.style.display === '') {
        el.style.display = 'block';
    } else {
        el.style.display = 'none';
    }
}

// ===================================
// BANK ANALYSIS CHARTS
// ===================================

// Bank data from Twig
const bankSummaryData = {{ bankSummary|json_encode|raw }};
const bankColors = ['#6366f1', '#8b5cf6', '#a78bfa', '#c4b5fd', '#3b82f6', '#60a5fa', '#93c5fd', '#10b981', '#f59e0b', '#ef4444'];

// Horizontal Bar Chart: Achat vs Vente by Bank
if (bankSummaryData.length > 0) {
    const topBanksSummary = bankSummaryData.slice(0, 10);
    new Chart(document.getElementById('chartBanquesComparatif'), {
        type: 'bar',
        data: {
            labels: topBanksSummary.map(b => {
                // Shorten long bank names
                const name = b.banque;
                return name.length > 15 ? name.substring(0, 14) + '…' : name;
            }),
            datasets: [
                {
                    label: 'Vente USD',
                    data: topBanksSummary.map(b => parseFloat(b.volumeVente) || 0),
                    backgroundColor: 'rgba(239, 68, 68, 0.75)',
                    borderColor: '#ef4444',
                    borderWidth: 1,
                    borderRadius: 4
                },
                {
                    label: 'Achat USD',
                    data: topBanksSummary.map(b => parseFloat(b.volumeAchat) || 0),
                    backgroundColor: 'rgba(16, 185, 129, 0.75)',
                    borderColor: '#10b981',
                    borderWidth: 1,
                    borderRadius: 4
                }
            ]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'top',
                    labels: {
                        usePointStyle: true,
                        pointStyle: 'rectRounded',
                        padding: 20,
                        font: { size: 12, family: 'Inter' }
                    }
                },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            return ctx.dataset.label + ': ' + new Intl.NumberFormat('fr-FR').format(ctx.raw) + ' USD';
                        }
                    }
                }
            },
            scales: {
                x: {
                    beginAtZero: true,
                    grid: { color: 'rgba(0,0,0,0.05)' },
                    ticks: {
                        callback: v => new Intl.NumberFormat('fr-FR', { notation: 'compact' }).format(v),
                        font: { family: 'Inter' }
                    }
                },
                y: {
                    grid: { display: false },
                    ticks: { font: { size: 11, family: 'Inter', weight: '500' } }
                }
            }
        }
    });

    // Donut: Market Share
    new Chart(document.getElementById('chartBanquesDonut'), {
        type: 'doughnut',
        data: {
            labels: topBanksSummary.map(b => b.banque),
            datasets: [{
                data: topBanksSummary.map(b => parseFloat(b.volumeTotal) || 0),
                backgroundColor: bankColors.slice(0, topBanksSummary.length),
                borderWidth: 2,
                borderColor: 'white',
                hoverOffset: 12
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutout: '60%',
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: function(ctx) {
                            const total = ctx.dataset.data.reduce((a, b) => a + b, 0);
                            const pct = ((ctx.raw / total) * 100).toFixed(1);
                            return ctx.label + ': ' + new Intl.NumberFormat('fr-FR').format(ctx.raw) + ' USD (' + pct + '%)';
                        }
                    }
                }
            }
        }
    });
}
</script>
{% endblock %}
