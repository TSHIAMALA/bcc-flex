{% extends 'base.html.twig' %}

{% block title %}Analyse & Décision{% endblock %}
{% block header_title %}Analyse & Aide à la Décision{% endblock %}
{% block header_subtitle %}Indicateurs synthétiques et scores de vigilance{% endblock %}

{% block body %}
<!-- Date Filter Bar -->
<div class="filter-bar mb-20">
    <div class="filter-bar-content">
        <div class="filter-section filter-title">
            <i class="fas fa-filter"></i>
            <span>Période</span>
        </div>
        <div class="filter-section filter-buttons">
            <a href="{{ path('app_analyse', {periode: '7jours'}) }}" class="filter-btn {{ periode == '7jours' ? 'active' : '' }}">7 jours</a>
            <a href="{{ path('app_analyse', {periode: '30jours'}) }}" class="filter-btn {{ periode == '30jours' ? 'active' : '' }}">30 jours</a>
            <a href="{{ path('app_analyse', {periode: '3mois'}) }}" class="filter-btn {{ periode == '3mois' ? 'active' : '' }}">3 mois</a>
        </div>
        <div class="filter-divider"></div>
        <form method="GET" action="{{ path('app_analyse') }}" class="filter-section filter-custom">
            <label>Du</label>
            <input type="date" name="dateDebut" value="{{ dateDebut }}" class="filter-date">
            <label>Au</label>
            <input type="date" name="dateFin" value="{{ dateFin }}" class="filter-date">
            <input type="hidden" name="periode" value="personnalise">
            <button type="submit" class="filter-apply-btn">
                <i class="fas fa-check"></i> Appliquer
            </button>
        </form>
    </div>
</div>

<!-- Header KPI Cards -->
<div class="kpi-header-grid mb-30">
    <div class="kpi-header-card">
        <div class="kpi-header-icon"><i class="fas fa-chart-bar"></i></div>
        <div class="kpi-header-content">
            <span class="kpi-header-label">TOTAL INDICATEURS</span>
            <span class="kpi-header-value">5</span>
        </div>
    </div>
    <div class="kpi-header-card highlight" style="flex-direction: column; align-items: stretch;">
        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
            <div class="kpi-header-content">
                <span class="kpi-header-label">
                    SCORE GLOBAL DE VIGILANCE
                    <button class="info-toggle" onclick="toggleInfo('vigilanceInfo')" style="color: rgba(255,255,255,0.8);"><i class="fas fa-question-circle"></i></button>
                </span>
                <span class="kpi-header-value">{{ scoreVigilance|number_format(1, ',', ' ') }}%</span>
            </div>
            <div class="kpi-header-icon"><i class="fas fa-shield-alt"></i></div>
        </div>
        <div id="vigilanceInfo" class="info-panel" style="margin-top: 15px; background: rgba(255, 255, 255, 0.15); color: white; border: 1px solid rgba(255,255,255,0.2); border-left: 4px solid white;">
            <h5 style="color: white;"><i class="fas fa-chart-pie"></i> Composition du Score</h5>
            <p>Moyenne pondérée des 5 indicateurs clés :</p>
            <ul style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; font-size: 0.8rem;">
                <li>• Stabilité Change : <strong>25%</strong></li>
                <li>• Niveau Réserves : <strong>25%</strong></li>
                <li>• Équilibre Budget : <strong>20%</strong></li>
                <li>• Liquidité Marché : <strong>15%</strong></li>
                <li>• Croissance Éco. : <strong>15%</strong></li>
            </ul>
        </div>
    </div>
    <div class="kpi-header-card" style="flex-direction: column; align-items: stretch; justify-content: center;">
        <div style="display: flex; justify-content: space-between; align-items: center; width: 100%;">
            <div class="kpi-header-content">
                <span class="kpi-header-label">
                    NIVEAU DE VIGILANCE
                    <button class="info-toggle" onclick="toggleInfo('niveauInfo')"><i class="fas fa-question-circle"></i></button>
                </span>
                <span class="kpi-header-value">{{ niveauVigilance }}</span>
            </div>
            <div class="kpi-header-progress">
                <div class="mini-progress">
                    <div class="mini-progress-fill {{ couleurVigilance }}" style="width: {{ scoreVigilance }}%"></div>
                </div>
            </div>
        </div>
        <div id="niveauInfo" class="info-panel" style="margin-top: 15px;">
            <h5><i class="fas fa-info-circle"></i> Échelle de Risque</h5>
            <p>Classification basée sur la performance globale des indicateurs :</p>
            <ul style="font-size: 0.8rem; display: flex; flex-direction: column; gap: 5px;">
                <li><i class="fas fa-circle" style="color: var(--success); font-size: 8px;"></i> <strong>Favorable (> 70%)</strong> : Situation saine.</li>
                <li><i class="fas fa-circle" style="color: var(--warning); font-size: 8px;"></i> <strong>Modéré (40-70%)</strong> : Points d'attention identifiés.</li>
                <li><i class="fas fa-circle" style="color: var(--danger); font-size: 8px;"></i> <strong>Critique (< 40%)</strong> : Intervention recommandée.</li>
            </ul>
        </div>
    </div>
    <div class="kpi-header-card">
        <div class="kpi-header-icon success"><i class="fas fa-calendar-check"></i></div>
        <div class="kpi-header-content">
            <span class="kpi-header-label">JOURS ANALYSÉS</span>
            <span class="kpi-header-value">{{ kpiData|length }}</span>
        </div>
    </div>
</div>

<!-- Row 1: Table with Progress + Donut Chart -->
<div class="grid-2 mb-30">
    <!-- Tableau des Indicateurs avec barres de progression -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-tasks"></i>
                Taux de Performance par Indicateur
                <button class="info-toggle" onclick="toggleInfo('perfInfo')"><i class="fas fa-question-circle"></i></button>
            </h3>
        </div>
        <div id="perfInfo" class="info-panel" style="margin: 0 20px 15px 20px; width: auto;">
            <h5><i class="fas fa-info-circle"></i> Comment lire ce tableau ?</h5>
            <p>Chaque indicateur est évalué sur un objectif de <strong>100%</strong> (Score de Performance). Les seuils sont <strong>paramétrables</strong> en base de données.</p>
            <ul>
                <li><strong>Stabilité du Change</strong> — Score calculé sur l'inverse de la pression sur le change (100 - Ecart/Diviseur).</li>
                <li><strong>Niveau des Réserves</strong> — Réserves internationales rapportées à l'objectif optimal paramétré (ex: 5 Mds USD).</li>
                <li><strong>Équilibre Budgétaire</strong> — Basé sur le Solde Budgétaire ou le ratio Recettes/Dépenses.</li>
                <li><strong>Liquidité Marché</strong> — Basé sur les Avoirs Libres par rapport à la cible optimale (ex: 1000 Mds CDF).</li>
                <li><strong>Croissance Économique</strong> — Évolution des recettes de l'État sur la période.</li>
            </ul>
            <p style="margin-top: 8px; font-size: 0.8rem;"><i class="fas fa-palette"></i> <strong>Couleurs :</strong> 
                <span style="color: #10b981;">■ &ge; 70% (Favorable)</span> · 
                <span style="color: #f59e0b;">■ 40-70% (Modéré)</span> · 
                <span style="color: #ef4444;">■ &lt; 40% (Critique)</span>
            </p>
        </div>
        <div class="table-container">
            <table class="data-table progress-table">
                <thead>
                    <tr>
                        <th>Indicateur</th>
                        <th>Objectif</th>
                        <th>Réalisé</th>
                        <th>Taux</th>
                        <th style="width: 150px;">Progression</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ind in indicateurs %}
                    {% set taux = (ind.realise / ind.planifie) * 100 %}
                    <tr>
                        <td><strong>{{ ind.nom }}</strong></td>
                        <td>{{ ind.planifie }}%</td>
                        <td>{{ ind.realise|number_format(1, ',', ' ') }}%</td>
                        <td>
                            <span class="taux-badge {{ taux >= 70 ? 'success' : (taux >= 40 ? 'warning' : 'danger') }}">
                                {{ taux|number_format(0) }}%
                            </span>
                        </td>
                        <td>
                            <div class="table-progress">
                                <div class="table-progress-fill {{ ind.couleur }}" style="width: {{ taux }}%"></div>
                            </div>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    <!-- Donut Répartition -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-chart-pie"></i>
                Répartition du Score par Indicateur
            </h3>
        </div>
        <div class="donut-wrapper">
            <div class="chart-container" style="height: 220px;">
                <canvas id="chartDonut"></canvas>
            </div>
            <div class="donut-legend-horizontal">
                {% set colors = ['#007FFF', '#3b82f6', '#10b981', '#f59e0b', '#8b5cf6'] %}
                {% for ind in indicateurs %}
                <div class="donut-legend-item">
                    <span class="donut-legend-color" style="background: {{ colors[loop.index0] }};"></span>
                    <span class="donut-legend-label">{{ ind.nom }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<!-- Row 2: Data Table + Bar Chart -->
<div class="grid-2 mb-30">
    <!-- Liste des Données Journalières -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-list"></i>
                Liste des Données Journalières
            </h3>
        </div>
        <div class="table-controls">
            <div class="table-search">
                <i class="fas fa-search"></i>
                <input type="text" placeholder="Rechercher..." id="searchInput">
            </div>
        </div>
        <div class="table-container" style="max-height: 350px; overflow-y: auto;">
            <table class="data-table" id="dataTable">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Cours BCC</th>
                        <th>Réserves</th>
                        <th>Taux Perf.</th>
                        <th>Score</th>
                    </tr>
                </thead>
                <tbody>
                    {% for kpi in kpiData %}
                    {% set perf = min(100, max(0, 100 - ((kpi.ecartIndicParallele|default(0)) / 2))) %}
                    <tr>
                        <td>{{ kpi.dateSituation|date('d/m/Y') }}</td>
                        <td class="font-bold">{{ kpi.coursIndicatif|number_format(2, ',', ' ') }}</td>
                        <td>{{ kpi.reservesInternationalesUsd|number_format(0, ',', ' ') }} M</td>
                        <td>
                            <div class="inline-progress">
                                <div class="inline-progress-fill" style="width: {{ perf }}%; background: {{ perf >= 70 ? '#10b981' : (perf >= 40 ? '#f59e0b' : '#ef4444') }};"></div>
                            </div>
                            <span class="inline-perf">{{ perf|number_format(0) }}%</span>
                        </td>
                        <td>
                            <span class="score-badge {{ kpi.solde >= 0 ? 'success' : 'danger' }}">
                                {{ kpi.solde >= 0 ? '+' : '' }}{{ kpi.solde|number_format(0, ',', ' ') }}
                            </span>
                        </td>
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        <div class="table-pagination">
            <span>Affichage de 1 à {{ kpiData|length }} sur {{ kpiData|length }} éléments</span>
        </div>
    </div>
    
    <!-- Histogramme des Indicateurs -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-chart-bar"></i>
                Histogramme de Performance
            </h3>
            <div class="chart-legend-inline">
                <span class="legend-dot primary"></span> Objectif
                <span class="legend-dot success"></span> Réalisé
            </div>
        </div>
        <div class="chart-container" style="height: 300px;">
            <canvas id="chartIndicateurs"></canvas>
        </div>
    </div>
</div>

<!-- ============================================================== -->
<!-- SECTION: ANALYSE DES BANQUES                                    -->
<!-- ============================================================== -->
<div class="section-divider mb-30">
    <div class="section-divider-line"></div>
    <div class="section-divider-title">
        <i class="fas fa-university"></i>
        Analyse des Banques Commerciales
    </div>
    <div class="section-divider-line"></div>
</div>

<!-- Bank KPI Cards -->
<div class="kpi-header-grid mb-30">
    <div class="kpi-header-card" style="border-left-color: #6366f1;">
        <div class="kpi-header-icon" style="background: rgba(99, 102, 241, 0.15); color: #6366f1;">
            <i class="fas fa-university"></i>
        </div>
        <div class="kpi-header-content">
            <span class="kpi-header-label">BANQUES ACTIVES</span>
            <span class="kpi-header-value">{{ nbBanquesActives }}</span>
        </div>
    </div>
    <div class="kpi-header-card" style="border-left-color: #8b5cf6;">
        <div class="kpi-header-icon" style="background: rgba(139, 92, 246, 0.15); color: #8b5cf6;">
            <i class="fas fa-exchange-alt"></i>
        </div>
        <div class="kpi-header-content">
            <span class="kpi-header-label">VOLUME TOTAL USD</span>
            <span class="kpi-header-value">{{ totalVolumeGlobal|number_format(0, ',', ' ') }}</span>
        </div>
    </div>
    <div class="kpi-header-card bank-highlight-vente">
        <div class="kpi-header-icon" style="background: rgba(239, 68, 68, 0.15); color: #ef4444;">
            <i class="fas fa-arrow-up"></i>
        </div>
        <div class="kpi-header-content">
            <span class="kpi-header-label">TOP VENDEUR</span>
            <span class="kpi-header-value" style="font-size: 1.1rem;">
                {% if topVendeur %}
                    {{ topVendeur.banque }}
                {% else %}
                    N/A
                {% endif %}
            </span>
            {% if topVendeur %}
            <span class="bank-volume-hint">{{ topVendeur.volumeTotalUsd|number_format(0, ',', ' ') }} USD</span>
            {% endif %}
        </div>
    </div>
    <div class="kpi-header-card bank-highlight-achat">
        <div class="kpi-header-icon" style="background: rgba(16, 185, 129, 0.15); color: #10b981;">
            <i class="fas fa-arrow-down"></i>
        </div>
        <div class="kpi-header-content">
            <span class="kpi-header-label">TOP ACHETEUR</span>
            <span class="kpi-header-value" style="font-size: 1.1rem;">
                {% if topAcheteur %}
                    {{ topAcheteur.banque }}
                {% else %}
                    N/A
                {% endif %}
            </span>
            {% if topAcheteur %}
            <span class="bank-volume-hint">{{ topAcheteur.volumeTotalUsd|number_format(0, ',', ' ') }} USD</span>
            {% endif %}
        </div>
    </div>
</div>

<!-- Bank Charts Row: Bar Chart Comparatif + Donut Répartition -->
<div class="grid-2 mb-30">
    <!-- Histogramme Comparatif Achat vs Vente -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-chart-bar"></i>
                Volume USD par Banque (Achat vs Vente)
                <button class="info-toggle" onclick="toggleInfo('bankChartInfo')"><i class="fas fa-question-circle"></i></button>
            </h3>
        </div>
        <div id="bankChartInfo" class="info-panel" style="margin: 0 20px 15px 20px; width: auto;">
            <h5><i class="fas fa-info-circle"></i> Comment lire ce graphique ?</h5>
            <p>Ce graphique compare les volumes de <strong>vente</strong> (barres rouges) et d'<strong>achat</strong> (barres vertes) de devises USD par banque commerciale sur la période sélectionnée.</p>
            <ul>
                <li>Les banques sont classées par volume total décroissant.</li>
                <li>Une forte asymétrie achat/vente peut indiquer une pression sur le change.</li>
            </ul>
        </div>
        <div class="chart-container" style="height: 350px; padding: 15px;">
            <canvas id="chartBanquesComparatif"></canvas>
        </div>
    </div>

    <!-- Donut Répartition par Banque -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-chart-pie"></i>
                Parts de Marché (Volume Total)
            </h3>
        </div>
        <div class="donut-wrapper">
            <div class="chart-container" style="height: 250px;">
                <canvas id="chartBanquesDonut"></canvas>
            </div>
            <div class="donut-legend-horizontal" id="bankDonutLegend">
                {% set bankColors = ['#6366f1', '#8b5cf6', '#a78bfa', '#c4b5fd', '#3b82f6', '#60a5fa', '#93c5fd', '#10b981', '#f59e0b', '#ef4444'] %}
                {% for bank in bankSummary|slice(0, 10) %}
                <div class="donut-legend-item">
                    <span class="donut-legend-color" style="background: {{ bankColors[loop.index0] ?? '#94a3b8' }};"></span>
                    <span class="donut-legend-label">{{ bank.banque }}</span>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</div>

<!-- Bank Tables Row: Top Vendeurs + Top Acheteurs -->
<div class="grid-2 mb-30">
    <!-- Top Banques Vendeuses -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-arrow-circle-up" style="color: #ef4444;"></i>
                Top Banques Vendeuses USD
            </h3>
            <span class="bank-total-badge vente">
                Total : {{ totalVolumeVente|number_format(0, ',', ' ') }} USD
            </span>
        </div>
        <div class="table-container" style="max-height: 400px; overflow-y: auto;">
            <table class="data-table bank-ranking-table" id="tableVendeurs">
                <thead>
                    <tr>
                        <th style="width: 40px;">#</th>
                        <th>Banque</th>
                        <th>Volume USD</th>
                        <th>Cours Moyen</th>
                        <th>Part (%)</th>
                        <th style="width: 120px;">Répartition</th>
                    </tr>
                </thead>
                <tbody>
                    {% for bank in topBanquesVente %}
                    {% set partVente = totalVolumeVente > 0 ? ((bank.volumeTotalUsd / totalVolumeVente) * 100) : 0 %}
                    <tr>
                        <td>
                            <span class="rank-badge {{ loop.index <= 3 ? 'top' ~ loop.index : '' }}">
                                {{ loop.index }}
                            </span>
                        </td>
                        <td><strong>{{ bank.banque }}</strong></td>
                        <td class="font-bold">{{ bank.volumeTotalUsd|number_format(0, ',', ' ') }}</td>
                        <td>{{ bank.coursMoyen|number_format(2, ',', ' ') }}</td>
                        <td>
                            <span class="taux-badge {{ partVente >= 20 ? 'danger' : (partVente >= 10 ? 'warning' : 'success') }}">
                                {{ partVente|number_format(1) }}%
                            </span>
                        </td>
                        <td>
                            <div class="table-progress">
                                <div class="table-progress-fill" style="width: {{ partVente }}%; background: linear-gradient(90deg, #ef4444, #f87171);"></div>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" style="text-align: center; padding: 30px; color: var(--text-secondary);"><i class="fas fa-info-circle"></i> Aucune transaction de vente sur cette période</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <!-- Top Banques Acheteuses -->
    <div class="card">
        <div class="card-header">
            <h3 class="card-title">
                <i class="fas fa-arrow-circle-down" style="color: #10b981;"></i>
                Top Banques Acheteuses USD
            </h3>
            <span class="bank-total-badge achat">
                Total : {{ totalVolumeAchat|number_format(0, ',', ' ') }} USD
            </span>
        </div>
        <div class="table-container" style="max-height: 400px; overflow-y: auto;">
            <table class="data-table bank-ranking-table" id="tableAcheteurs">
                <thead>
                    <tr>
                        <th style="width: 40px;">#</th>
                        <th>Banque</th>
                        <th>Volume USD</th>
                        <th>Cours Moyen</th>
                        <th>Part (%)</th>
                        <th style="width: 120px;">Répartition</th>
                    </tr>
                </thead>
                <tbody>
                    {% for bank in topBanquesAchat %}
                    {% set partAchat = totalVolumeAchat > 0 ? ((bank.volumeTotalUsd / totalVolumeAchat) * 100) : 0 %}
                    <tr>
                        <td>
                            <span class="rank-badge {{ loop.index <= 3 ? 'top' ~ loop.index : '' }}">
                                {{ loop.index }}
                            </span>
                        </td>
                        <td><strong>{{ bank.banque }}</strong></td>
                        <td class="font-bold">{{ bank.volumeTotalUsd|number_format(0, ',', ' ') }}</td>
                        <td>{{ bank.coursMoyen|number_format(2, ',', ' ') }}</td>
                        <td>
                            <span class="taux-badge {{ partAchat >= 20 ? 'success' : (partAchat >= 10 ? 'warning' : 'info') }}">
                                {{ partAchat|number_format(1) }}%
                            </span>
                        </td>
                        <td>
                            <div class="table-progress">
                                <div class="table-progress-fill" style="width: {{ partAchat }}%; background: linear-gradient(90deg, #10b981, #34d399);"></div>
                            </div>
                        </td>
                    </tr>
                    {% else %}
                    <tr><td colspan="6" style="text-align: center; padding: 30px; color: var(--text-secondary);"><i class="fas fa-info-circle"></i> Aucune transaction d'achat sur cette période</td></tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Bank Summary Table (Full width) -->
<div class="card mb-30">
    <div class="card-header">
        <h3 class="card-title">
            <i class="fas fa-table"></i>
            Synthèse Complète par Banque
            <button class="info-toggle" onclick="toggleInfo('bankSummaryInfo')"><i class="fas fa-question-circle"></i></button>
        </h3>
    </div>
    <div id="bankSummaryInfo" class="info-panel" style="margin: 0 20px 15px 20px; width: auto;">
        <h5><i class="fas fa-info-circle"></i> Comprendre cette synthèse</h5>
        <p>Ce tableau présente pour chaque banque commerciale une vue consolidée de son activité sur le marché des changes :</p>
        <ul>
            <li><strong>Volume Achat</strong> — Total des USD achetés par la banque</li>
            <li><strong>Volume Vente</strong> — Total des USD vendus par la banque</li>
            <li><strong>Position Nette</strong> — Différence (Achat − Vente). Un solde <strong>positif</strong> signifie que la banque achète plus qu'elle ne vend (demande nette de USD).</li>
            <li><strong>Cours Moyen</strong> — Cours moyen pondéré pratiqué à l'achat et à la vente</li>
        </ul>
    </div>
    <div class="table-container" style="max-height: 500px; overflow-y: auto;">
        <table class="data-table bank-summary-table" id="tableSynthese">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Banque</th>
                    <th>Vol. Achat (USD)</th>
                    <th>Vol. Vente (USD)</th>
                    <th>Vol. Total (USD)</th>
                    <th>Position Nette</th>
                    <th>Cours Moy. Achat</th>
                    <th>Cours Moy. Vente</th>
                    <th>Nb Trans.</th>
                </tr>
            </thead>
            <tbody>
                {% for bank in bankSummary %}
                {% set positionNette = (bank.volumeAchat|default(0)) - (bank.volumeVente|default(0)) %}
                <tr>
                    <td>
                        <span class="rank-badge {{ loop.index <= 3 ? 'top' ~ loop.index : '' }}">{{ loop.index }}</span>
                    </td>
                    <td><strong>{{ bank.banque }}</strong></td>
                    <td style="color: #10b981; font-weight: 600;">{{ bank.volumeAchat|number_format(0, ',', ' ') }}</td>
                    <td style="color: #ef4444; font-weight: 600;">{{ bank.volumeVente|number_format(0, ',', ' ') }}</td>
                    <td class="font-bold">{{ bank.volumeTotal|number_format(0, ',', ' ') }}</td>
                    <td>
                        <span class="score-badge {{ positionNette >= 0 ? 'success' : 'danger' }}">
                            {{ positionNette >= 0 ? '+' : '' }}{{ positionNette|number_format(0, ',', ' ') }}
                        </span>
                    </td>
                    <td>{{ bank.coursMoyenAchat ? bank.coursMoyenAchat|number_format(2, ',', ' ') : '—' }}</td>
                    <td>{{ bank.coursMoyenVente ? bank.coursMoyenVente|number_format(2, ',', ' ') : '—' }}</td>
                    <td>{{ bank.nbTransactions }}</td>
                </tr>
                {% else %}
                <tr><td colspan="9" style="text-align: center; padding: 30px; color: var(--text-secondary);"><i class="fas fa-info-circle"></i> Aucune donnée bancaire disponible pour cette période</td></tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<!-- Row 3: Analysis Cards -->
<div class="grid-3">
    <!-- Pression Change -->
    <div class="analysis-card {{ pressionChange < 30 ? 'success' : (pressionChange < 60 ? 'warning' : 'danger') }}">
        <div class="analysis-top-row">
            <div class="analysis-icon">
                <i class="fas fa-bolt"></i>
            </div>
            <div class="analysis-content">
                <h4>
                    Pression Change 
                    <button class="info-toggle" onclick="toggleInfo('pressionInfo')"><i class="fas fa-question-circle"></i></button>
                </h4>
                <div class="analysis-value">{{ pressionChange|number_format(0) }}%</div>
                <p>{{ pressionChange < 30 ? 'Situation stable' : (pressionChange < 60 ? 'Vigilance requise' : 'Intervention recommandée') }}</p>
            </div>
            <div class="analysis-gauge">
                <svg viewBox="0 0 36 36">
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e0e0e0" stroke-width="3"/>
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="{{ pressionChange }}, 100"/>
                </svg>
            </div>
        </div>
        <div id="pressionInfo" class="info-panel">
            <h5><i class="fas fa-info-circle"></i> Comprendre l'indicateur</h5>
            <p>Cet indice mesure la tension sur le marché des changes. Il est calculé à partir de l'écart entre le taux indicatif et le taux parallèle, pondéré par un facteurs de tolérance (diviseur paramétrable).</p>
            <ul>
                <li><strong>Stable (< 30%)</strong> : Pression faible, l'écart est dans les normes acceptables.</li>
                <li><strong>Vigilance (30-60%)</strong> : Pression modérée, l'écart commence à se creuser.</li>
                <li><strong>Tension (> 60%)</strong> : Pression forte, écart significatif nécessitant attention.</li>
            </ul>
        </div>
    </div>
    
    <!-- Niveau Réserves -->
    <div class="analysis-card {{ niveauReserves > 70 ? 'success' : (niveauReserves > 40 ? 'warning' : 'danger') }}">
        <div class="analysis-top-row">
            <div class="analysis-icon">
                <i class="fas fa-piggy-bank"></i>
            </div>
            <div class="analysis-content">
                <h4>
                    Niveau Réserves
                    <button class="info-toggle" onclick="toggleInfo('reservesInfo')"><i class="fas fa-question-circle"></i></button>
                </h4>
                <div class="analysis-value">{{ niveauReserves|number_format(0) }}%</div>
                <p>{{ niveauReserves > 70 ? 'Réserves solides' : (niveauReserves > 40 ? 'Niveau acceptable' : 'Renforcement nécessaire') }}</p>
            </div>
            <div class="analysis-gauge">
                <svg viewBox="0 0 36 36">
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e0e0e0" stroke-width="3"/>
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="{{ niveauReserves }}, 100"/>
                </svg>
            </div>
        </div>
        <div id="reservesInfo" class="info-panel">
            <h5><i class="fas fa-info-circle"></i> Comprendre l'indicateur</h5>
            <p>Niveau d'adéquation des réserves de change par rapport à un objectif stratégique paramétrable (ex: 5 Mds USD).</p>
            <ul>
                <li><strong>Solide (> 70%)</strong> : Couverture confortable des importations.</li>
                <li><strong>Acceptable (40-70%)</strong> : Niveau suffisant à court terme.</li>
                <li><strong>Faible (< 40%)</strong> : Vulnérabilité aux chocs externes.</li>
            </ul>
        </div>
    </div>
    
    <!-- Équilibre Budget -->
    <div class="analysis-card {{ equilibreBudget > 70 ? 'success' : (equilibreBudget > 40 ? 'warning' : 'danger') }}">
        <div class="analysis-top-row">
            <div class="analysis-icon">
                <i class="fas fa-balance-scale"></i>
            </div>
            <div class="analysis-content">
                <h4>
                    Équilibre Budget
                    <button class="info-toggle" onclick="toggleInfo('budgetInfo')"><i class="fas fa-question-circle"></i></button>
                </h4>
                <div class="analysis-value">{{ equilibreBudget|number_format(0) }}%</div>
                <p>{{ equilibreBudget > 70 ? 'Budget équilibré' : (equilibreBudget > 40 ? 'Déficit contenu' : 'Consolidation urgente') }}</p>
            </div>
            <div class="analysis-gauge">
                <svg viewBox="0 0 36 36">
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="#e0e0e0" stroke-width="3"/>
                    <path d="M18 2.0845 a 15.9155 15.9155 0 0 1 0 31.831 a 15.9155 15.9155 0 0 1 0 -31.831" fill="none" stroke="currentColor" stroke-width="3" stroke-dasharray="{{ equilibreBudget }}, 100"/>
                </svg>
            </div>
        </div>
        <div id="budgetInfo" class="info-panel">
            <h5><i class="fas fa-info-circle"></i> Comprendre l'indicateur</h5>
            <p>Taux de couverture des dépenses publiques par les recettes mobilisées sur la période.</p>
            <ul>
                <li><strong>Équilibré (> 70%)</strong> : Gestion saine, recettes suffisantes.</li>
                <li><strong>Déficit contenu (40-70%)</strong> : Écart maîtrisable.</li>
                <li><strong>Critique (< 40%)</strong> : Dépenses très supérieures aux recettes.</li>
            </ul>
        </div>
    </div>
</div>

