{% extends 'base.html.twig' %}

{% block title %}Fiche Journalière{% endblock %}
{% block header_title %}Fiche Quotidienne de Décision{% endblock %}
{% block header_subtitle %}Stabilité monétaire & Taux de change{% endblock %}

{% block stylesheets %}
<style>
/* ─── Fiche Journalière ─── */
.fiche-container { max-width: 1200px; margin: 0 auto; }

/* Header banner */
.fiche-banner {
    background: linear-gradient(135deg, #1e4b7a 0%, #2d6da6 60%, #1a8cff 100%);
    border-radius: 16px;
    padding: 28px 32px;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 28px;
    box-shadow: 0 8px 32px rgba(30,75,122,0.3);
}
.fiche-banner h2 { font-size: 1.5rem; font-weight: 800; margin: 0; }
.fiche-banner .date-badge {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 50px;
    padding: 6px 20px;
    font-size: 0.95rem;
    font-weight: 600;
    backdrop-filter: blur(4px);
}
.fiche-banner .banner-actions { display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }

/* Date selector */
.date-selector-form select {
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.3);
    color: #fff;
    border-radius: 8px;
    padding: 6px 12px;
    font-size: 0.9rem;
    cursor: pointer;
}
.date-selector-form select option { background: #1e4b7a; color: #fff; }

/* Signal badge */
.signal-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 14px; border-radius: 50px;
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;
}
.signal-green  { background: #d4edda; color: #155724; }
.signal-yellow { background: #fff3cd; color: #856404; }
.signal-orange { background: #ffe5cc; color: #8a4700; }
.signal-red    { background: #f8d7da; color: #721c24; }
.signal-secondary { background: #e9ecef; color: #6c757d; }

/* Pillar cards - uses global .card class for dark mode support */
.pillars-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 20px;
    margin-bottom: 28px;
}
.pillar-card .pillar-icon {
    width: 48px; height: 48px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem; margin-bottom: 14px;
}
.pillar-card .pillar-title { font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-secondary); margin-bottom: 6px; }
.pillar-card .pillar-value { font-size: 2rem; font-weight: 800; margin-bottom: 4px; font-variant-numeric: tabular-nums; color: var(--text-primary); }
.pillar-card .pillar-sub   { font-size: 0.85rem; color: var(--text-secondary); }
.pillar-card .pillar-badge { position: absolute; top: 18px; right: 18px; }

/* Colour accents per signal */
.pillar-green  .pillar-icon { background: #d4edda; color: #155724; }
.pillar-orange .pillar-icon { background: #ffe5cc; color: #8a4700; }
.pillar-red    .pillar-icon { background: #f8d7da; color: #721c24; }
.pillar-yellow .pillar-icon { background: #fff3cd; color: #856404; }
.pillar-secondary .pillar-icon { background: #e9ecef; color: #6c757d; }

/* Scenario widget */
.scenario-widget {
    border-radius: 16px;
    padding: 24px 28px;
    display: flex; align-items: flex-start; gap: 20px;
    margin-bottom: 28px;
    border: 2px solid;
    flex-wrap: wrap;
    background: var(--bg-card);
    color: var(--text-primary);
}
.scenario-widget.scenario-1 { background: #f0fff4; border-color: #38a169; }
.scenario-widget.scenario-2 { background: #fffaf0; border-color: #dd6b20; }
.scenario-widget.scenario-3 { background: #fff5f5; border-color: #c53030; }
.scenario-number {
    font-size: 3rem; font-weight: 900; line-height: 1;
    width: 70px; height: 70px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
}
.scenario-1 .scenario-number { background: #38a169; color: #fff; }
.scenario-2 .scenario-number { background: #dd6b20; color: #fff; }
.scenario-3 .scenario-number { background: #c53030; color: #fff; }
.scenario-body h3 { font-size: 1.1rem; font-weight: 800; margin: 0 0 4px; color: var(--text-primary); }
.scenario-body p  { font-size: 0.9rem; color: var(--text-secondary); margin: 0 0 8px; }
.scenario-body .justification { font-size: 0.85rem; font-style: italic; color: var(--text-secondary); }

/* Cabinet phrase */
.phrase-cabinet {
    background: linear-gradient(135deg, #1e4b7a08, #2d6da610);
    border: 1px solid #2d6da630;
    border-left: 4px solid #2d6da6;
    border-radius: 12px;
    padding: 20px 24px;
    margin-bottom: 28px;
    font-size: 1rem;
    font-style: italic;
    color: #1e4b7a;
    line-height: 1.7;
}

/* Detail table */
.detail-section { margin-bottom: 28px; }
.detail-section h3 {
    font-size: 0.8rem; font-weight: 700; text-transform: uppercase;
    letter-spacing: 1px; color: var(--text-secondary); margin-bottom: 12px;
    display: flex; align-items: center; gap: 8px;
}
.detail-section h3::after {
    content: ''; flex: 1; height: 1px; background: #e9ecef;
}
.mini-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
.mini-table td { padding: 8px 12px; border-bottom: 1px solid #f0f0f0; color: var(--text-primary); }
.mini-table td:first-child { color: var(--text-secondary); font-weight: 500; width: 55%; }
.mini-table td:last-child  { font-weight: 700; text-align: right; }

/* Table wrappers */
.table-wrapper {
    background: var(--bg-card);
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 12px;
    overflow: hidden;
}

/* Alert points */
.attention-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 10px; }
.attention-list li {
    display: flex; align-items: flex-start; gap: 10px;
    background: var(--bg-card);
    border: 1px solid rgba(0,0,0,0.05);
    border-radius: 10px;
    padding: 12px 16px;
    font-size: 0.9rem;
    color: var(--text-primary);
}
.attention-list .attn-icon { font-size: 1.1rem; flex-shrink: 0; }

/* Export button */
.btn-pdf {
    background: #dc3545; color: #fff; border: none; border-radius: 8px;
    padding: 8px 18px; font-weight: 700; font-size: 0.88rem;
    display: inline-flex; align-items: center; gap: 6px;
    cursor: pointer; text-decoration: none;
    transition: background .2s, transform .15s;
}
.btn-pdf:hover { background: #b02a37; color: #fff; transform: scale(1.03); }

/* Global signal border top */
.pillar-card.signal-top-green  { border-top: 4px solid #38a169; }
.pillar-card.signal-top-yellow { border-top: 4px solid #ecc94b; }
.pillar-card.signal-top-orange { border-top: 4px solid #dd6b20; }
.pillar-card.signal-top-red    { border-top: 4px solid #c53030; }
.pillar-card.signal-top-secondary { border-top: 4px solid #adb5bd; }

@media (max-width: 640px) {
    .fiche-banner { flex-direction: column; }
    .pillars-grid { grid-template-columns: 1fr; }
}

/* threshold header */
.thresholds-header { background: #f8f9fa; color: var(--text-primary); }
.thresholds-header td { background: inherit; color: inherit; }
[data-theme="dark"] .thresholds-header,
body.dark-mode .thresholds-header { background: #1e293b; color: #fff; }
[data-theme="dark"] .thresholds-header td,
body.dark-mode .thresholds-header td { background: inherit; color: inherit; }
</style>
{% endblock %}

{% macro signal_badge(color) %}
    {% set labels = {green: 'Normal', yellow: 'Vigilance', orange: 'Alerte', red: 'Critique', secondary: 'N/D'} %}
    {% set emoji  = {green: '🟢', yellow: '🟡', orange: '🟠', red: '🔴', secondary: '⚪'} %}
    <span class="signal-badge signal-{{ color }}">
        {{ emoji[color] ?? '⚪' }} {{ labels[color] ?? color }}
    </span>
{% endmacro %}

{% macro fmt_num(val, dec, suffix) %}
    {% if val is not null %}{{ val|number_format(dec ?? 2, ',', ' ') }}{{ suffix ?? '' }}{% else %}<span class="text-muted">N/D</span>{% endif %}
{% endmacro %}

{% import _self as fiche %}

{% block body %}
<div class="fiche-container">

    {# ────────── BANNER ────────── #}
    <div class="fiche-banner">
        <div>
            <div style="font-size:0.8rem;opacity:.8;margin-bottom:4px;">BANQUE CENTRALE DU CONGO — Cabinet</div>
            <h2><i class="fas fa-file-contract me-2"></i>Fiche Quotidienne — Stabilité Monétaire</h2>
            <div class="mt-2">
                <span class="date-badge">
                    <i class="fas fa-calendar-day me-1"></i>
                    Situation au {{ date ? date|date('d/m/Y') : 'N/D' }}
                </span>
            </div>
        </div>
        <div class="banner-actions">
            {# Date selector #}
            <form method="GET" action="{{ path('app_fiche_journaliere') }}" class="date-selector-form">
                <select name="date" onchange="this.form.submit()">
                    {% for d in availableDates %}
                        <option value="{{ d.dateSituation|date('Y-m-d') }}"
                            {{ d.dateSituation|date('Y-m-d') == date|date('Y-m-d') ? 'selected' : '' }}>
                            {{ d.dateSituation|date('d/m/Y') }}
                        </option>
                    {% endfor %}
                </select>
            </form>
            {# PDF Export #}
            <a href="{{ path('app_fiche_journaliere_pdf', {date: date|date('Y-m-d')}) }}" class="btn-pdf">
                <i class="fas fa-file-pdf"></i> Exporter PDF
            </a>
            {# PPTX Export #}
            <a href="{{ path('app_fiche_journaliere_slides', {date: date|date('Y-m-d')}) }}" class="btn-pdf" style="background:#ed8004;">
                <i class="fas fa-file-powerpoint"></i> Exporter PPTX
            </a>
        </div>
    </div>

    {# ────────── SCÉNARIO RECOMMANDÉ ────────── #}
    <div class="scenario-widget scenario-{{ scenario.scenario }}">
        <div class="scenario-number">{{ scenario.scenario }}</div>
        <div class="scenario-body">
            <h3>Scénario recommandé : {{ scenario.label }}</h3>
            <p>
                {% if scenario.scenario == 1 %}
                    Maintenir la posture actuelle. Surveillance renforcée sans action corrective majeure.
                {% elseif scenario.scenario == 2 %}
                    Renforcer la stérilisation, ajuster le signal de change, coordonner avec le Trésor.
                {% else %}
                    Absorption massive de liquidité, intervention FX ciblée, coordination urgente Trésor–BCC.
                {% endif %}
            </p>
            {% if scenario.justification %}
                <div class="justification"><i class="fas fa-info-circle me-1"></i>{{ scenario.justification }}</div>
            {% endif %}
        </div>
    </div>

    {# ────────── 4 PILIERS ────────── #}
    <div class="pillars-grid">

        {# Pilier 1 : Change #}
        <div class="card pillar-card pillar-{{ signalChange }} signal-top-{{ signalChange }}">
            <div class="pillar-badge">{{ fiche.signal_badge(signalChange) }}</div>
            <div class="pillar-icon"><i class="fas fa-exchange-alt"></i></div>
            <div class="pillar-title">Pilier 1 — Marché des Changes</div>
            <div class="pillar-value">
                {% if ecartPct is not null %}{{ ecartPct|number_format(2, ',', ' ') }} %{% else %}N/D{% endif %}
            </div>
            <div class="pillar-sub">Écart moyen indicatif / parallèle</div>
            <table class="mini-table mt-3">
                <tr><td>Taux indicatif</td>
                    <td>{{ marche ? marche.coursIndicatif|number_format(4, ',', ' ') : 'N/D' }} CDF</td></tr>
                <tr><td>Parallèle (achat / vente)</td>
                    <td>{% if marche %}{{ marche.paralleleAchat|number_format(2,',') }} / {{ marche.paralleleVente|number_format(2,',') }}{% else %}N/D{% endif %}</td></tr>
                <tr><td>Écart absolu</td>
                    <td>{{ marche ? marche.ecartIndicParallele|number_format(2,',') : 'N/D' }} CDF</td></tr>
                <tr><td>Écart max (borne haute)</td>
                    <td>{% if ecartMaxPct is not null %}{{ ecartMaxPct|number_format(2,',') }} %{% else %}N/D{% endif %}</td></tr>
                <tr><td>Spread parallèle</td>
                    <td>{% if spreadPct is not null %}{{ spreadPct|number_format(2,',') }} %{% else %}N/D{% endif %}</td></tr>
            </table>
        </div>

        {# Pilier 2 : Réserves #}
        <div class="card pillar-card pillar-{{ signalReserves }} signal-top-{{ signalReserves }}">
            <div class="pillar-badge">{{ fiche.signal_badge(signalReserves) }}</div>
            <div class="pillar-icon"><i class="fas fa-shield-alt"></i></div>
            <div class="pillar-title">Pilier 2 — Position Extérieure</div>
            <div class="pillar-value">
                {% if reserves and reserves.reservesInternationalesUsd %}
                    {{ (reserves.reservesInternationalesUsd / 1000)|number_format(2, ',', ' ') }} Md$
                {% else %}N/D{% endif %}
            </div>
            <div class="pillar-sub">Réserves internationales</div>
            <table class="mini-table mt-3">
                <tr><td>Réserves int. (USD Mios)</td>
                    <td>{{ reserves ? reserves.reservesInternationalesUsd|number_format(2,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Avoirs externes (USD Mios)</td>
                    <td>{{ reserves ? reserves.avoirsExternesUsd|number_format(2,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Couverture (seuil 5 Md$)</td>
                    <td>
                        {% if reserves and reserves.reservesInternationalesUsd %}
                            {{ (reserves.reservesInternationalesUsd / 5000 * 100)|number_format(0) }} %
                        {% else %}N/D{% endif %}
                    </td></tr>
            </table>
        </div>

        {# Pilier 3 : Liquidité #}
        <div class="card pillar-card pillar-{{ signalLiquidite }} signal-top-{{ signalLiquidite }}">
            <div class="pillar-badge">{{ fiche.signal_badge(signalLiquidite) }}</div>
            <div class="pillar-icon"><i class="fas fa-water"></i></div>
            <div class="pillar-title">Pilier 3 — Liquidité & Stérilisation</div>
            <div class="pillar-value">
                {% if reserves and reserves.avoirsLibresCdf %}
                    {{ reserves.avoirsLibresCdf|number_format(0,',',' ') }}
                {% else %}N/D{% endif %}
            </div>
            <div class="pillar-sub">Avoirs libres (Mds CDF)</div>
            <table class="mini-table mt-3">
                <tr><td>Réserves des banques (CDF)</td>
                    <td>{{ reserves ? reserves.reservesBanquesCdf|number_format(0,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Encours OT-BCC</td>
                    <td>{{ encours ? encours.encoursOtBcc|number_format(2,',') : 'N/D' }}</td></tr>
                <tr><td>Encours B-BCC</td>
                    <td>{{ encours ? encours.encoursBBcc|number_format(2,',') : 'N/D' }}</td></tr>
                <tr><td>Ratio stérilisation</td>
                    <td>{% if ratioSteri is not null %}{{ ratioSteri|number_format(2,',') }}{% else %}N/D{% endif %}
                        {% if ratioSteri is not null %}
                            <span class="ms-1 {% if ratioSteri >= 1.5 %}text-success{% elseif ratioSteri >= 1 %}text-warning{% else %}text-danger{% endif %}">
                                ({{ ratioSteri >= 1.5 ? '✓ Efficace' : (ratioSteri >= 1 ? '⚠ Partiel' : '✗ Insuffisant') }})
                            </span>
                        {% endif %}
                    </td></tr>
            </table>
        </div>

        {# Pilier 4 : Budget & Trésorerie #}
        <div class="card pillar-card pillar-{{ signalTresorerie }} signal-top-{{ signalTresorerie }}">
            <div class="pillar-badge">{{ fiche.signal_badge(signalTresorerie) }}</div>
            <div class="pillar-icon"><i class="fas fa-landmark"></i></div>
            <div class="pillar-title">Pilier 4 — Budget & Trésorerie</div>
            <div class="pillar-value">
                {% if tresorerie and tresorerie.soldeAvantFin %}
                    {{ tresorerie.soldeAvantFin|number_format(0, ',', ' ') }}
                {% else %}N/D{% endif %}
            </div>
            <div class="pillar-sub">Solde trésorerie avant fin (Mds CDF)</div>
            <table class="mini-table mt-3">
                <tr><td>Recettes totales</td>
                    <td>{{ finances ? finances.recettesTotales|number_format(2,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Dépenses totales</td>
                    <td>{{ finances ? finances.depensesTotales|number_format(2,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Solde après fin</td>
                    <td>{{ tresorerie ? tresorerie.soldeApresFin|number_format(2,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Solde cumulé annuel</td>
                    <td>{{ tresorerie ? tresorerie.soldeCumuleAnnee|number_format(2,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Paie exécutée</td>
                    <td>{% if tauxPaie is not null %}{{ tauxPaie|number_format(1,',') }} %{% else %}N/D{% endif %}
                        {{ fiche.signal_badge(signalPaie) }}
                    </td></tr>
                <tr><td>Reste à payer</td>
                    <td>{{ paie ? paie.montantRestant|number_format(2,',',' ') : 'N/D' }} Mds</td></tr>
            </table>
        </div>
    </div>

    {# ────────── PHRASE CABINET ────────── #}
    <div class="phrase-cabinet">
        <div style="font-size:0.75rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;margin-bottom:8px;font-style:normal;color:#2d6da6;">
            <i class="fas fa-quote-left me-2"></i>Synthèse — Niveau Cabinet
        </div>
        {{ phraseCabinet }}
    </div>

    {# ────────── POINTS D'ATTENTION ────────── #}
    <div class="detail-section">
        <h3><i class="fas fa-exclamation-triangle"></i> Points d'attention immédiats</h3>
        <ul class="attention-list">
            {% if signalChange in ['orange','red'] %}
            <li>
                <span class="attn-icon">🟠</span>
                <span><strong>Désalignement de change :</strong>
                    Écart moyen {% if ecartPct %}{{ ecartPct|number_format(1,',') }}%{% endif %}.
                    Vérifier la cohérence du signal indicatif et ajuster si nécessaire.
                </span>
            </li>
            {% endif %}
            {% if signalLiquidite in ['orange','red'] %}
            <li>
                <span class="attn-icon">💧</span>
                <span><strong>Surliquidité bancaire :</strong>
                    Avoirs libres {% if reserves %}{{ reserves.avoirsLibresCdf|number_format(0,',',' ') }} Mds CDF{% endif %}.
                    Renforcer les instruments de stérilisation (B-BCC / OT-BCC).
                </span>
            </li>
            {% endif %}
            {% if signalTresorerie in ['yellow','orange','red'] %}
            <li>
                <span class="attn-icon">🏛️</span>
                <span><strong>Tension de trésorerie :</strong>
                    Solde avant fin {% if tresorerie %}{{ tresorerie.soldeAvantFin|number_format(0,',',' ') }} Mds{% endif %}.
                    Coordonner le phasage des paiements publics.
                </span>
            </li>
            {% endif %}
            {% if signalPaie in ['orange','red'] %}
            <li>
                <span class="attn-icon">💼</span>
                <span><strong>Choc de paie à venir :</strong>
                    Reste {% if paie %}{{ paie.montantRestant|number_format(0,',',' ') }} Mds CDF{% endif %}
                    ({% if pctRestePaie %}{{ pctRestePaie|number_format(0) }}%{% endif %} non exécuté).
                    Anticiper l'impact sur la liquidité et le change.
                </span>
            </li>
            {% endif %}
            {% if signalChange == 'green' and signalLiquidite == 'green' and signalTresorerie == 'green' %}
            <li>
                <span class="attn-icon">✅</span>
                <span><strong>Situation favorable :</strong> Tous les indicateurs principaux sont dans les normes. Maintenir la surveillance quotidienne.</span>
            </li>
            {% endif %}
        </ul>
    </div>

    {# ────────── SOLDES TRÉSORERIE DÉTAIL (si disponibles) ────────── #}
    {% if tresorerie and (tresorerie.soldeCgt or tresorerie.depensesUrgence) %}
    <div class="detail-section">
        <h3><i class="fas fa-table"></i> Soldes de trésorerie détaillés</h3>
        <div class="table-wrapper">
            <table class="mini-table">
                <tr><td>CGT</td><td>{{ tresorerie.soldeCgt ? tresorerie.soldeCgt|number_format(2,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Dépenses d'urgence</td><td>{{ tresorerie.depensesUrgence ? tresorerie.depensesUrgence|number_format(2,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Excédent</td><td>{{ tresorerie.excedent ? tresorerie.excedent|number_format(2,',',' ') : 'N/D' }}</td></tr>
                <tr><td>Réserve sous titres</td><td>{{ tresorerie.reserveSousTitres ? tresorerie.reserveSousTitres|number_format(2,',',' ') : 'N/D' }}</td></tr>
            </table>
        </div>
    </div>
    {% endif %}

    {# ────────── SEUILS D'ALERTE DE RÉFÉRENCE ────────── #}
    <div class="detail-section">
        <h3><i class="fas fa-sliders-h"></i> Seuils d'alerte de référence</h3>
        <div class="table-wrapper">
            <table class="mini-table">
                <thead><tr class="thresholds-header">
                    <td><strong>Indicateur</strong></td>
                    <td style="text-align:center;"><strong>🟢 Normal</strong></td>
                    <td style="text-align:center;"><strong>🟡 Vigilance</strong></td>
                    <td style="text-align:center;"><strong>🟠 Alerte</strong></td>
                    <td style="text-align:center;"><strong>🔴 Critique</strong></td>
                </tr></thead>
                <tr><td>Écart moyen indicatif/parallèle</td><td style="text-align:center;">≤ 2%</td><td style="text-align:center;">2–3%</td><td style="text-align:center;">3–5%</td><td style="text-align:center;">&gt; 5%</td></tr>
                <tr><td>Écart max (borne haute)</td><td style="text-align:center;">≤ 3%</td><td style="text-align:center;">—</td><td style="text-align:center;">3–6%</td><td style="text-align:center;">&gt; 6%</td></tr>
                <tr><td>Avoirs libres (Mds CDF)</td><td style="text-align:center;">&lt; 800</td><td style="text-align:center;">—</td><td style="text-align:center;">800–1 200</td><td style="text-align:center;">&gt; 1 200</td></tr>
