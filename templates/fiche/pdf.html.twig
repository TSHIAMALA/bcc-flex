<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<title>Fiche Journalière BCC — {{ date ? date|date('d/m/Y') : '' }}</title>
<style>
* { margin: 0; padding: 0; box-sizing: border-box; }
body { font-family: DejaVu Sans, Arial, sans-serif; font-size: 10pt; color: #1a1a2e; background: #fff; }

/* PAGE */
.page { width: 100%; max-width: 740px; margin: 0 auto; padding: 20px 28px; }

/* HEADER */
.header {
    background: linear-gradient(135deg, #1e4b7a, #2d6da6);
    color: #fff;
    border-radius: 10px;
    padding: 16px 20px;
    margin-bottom: 16px;
    display: table;
    width: 100%;
}
.header-left  { display: table-cell; vertical-align: middle; }
.header-right { display: table-cell; vertical-align: middle; text-align: right; }
.header h1  { font-size: 14pt; font-weight: bold; margin-bottom: 2px; }
.header .sub { font-size: 8pt; opacity: 0.85; }
.date-badge {
    background: rgba(255,255,255,0.2);
    border: 1px solid rgba(255,255,255,0.35);
    border-radius: 20px;
    padding: 4px 14px;
    font-size: 9pt;
    font-weight: bold;
}
.confidential {
    font-size: 7pt;
    text-transform: uppercase;
    letter-spacing: 1px;
    opacity: 0.75;
    margin-top: 4px;
}

/* SCENARIO BANNER */
.scenario-banner {
    border-radius: 8px;
    padding: 12px 16px;
    margin-bottom: 16px;
    border: 2px solid;
    display: table;
    width: 100%;
}
.scenario-banner.s1 { background: #f0fff4; border-color: #38a169; }
.scenario-banner.s2 { background: #fffaf0; border-color: #dd6b20; }
.scenario-banner.s3 { background: #fff5f5; border-color: #c53030; }
.scenario-num-cell { display: table-cell; vertical-align: middle; width: 52px; }
.scenario-num {
    font-size: 22pt; font-weight: 900; width: 46px; height: 46px;
    border-radius: 10px; text-align: center; line-height: 46px; color: #fff;
}
.s1 .scenario-num { background: #38a169; }
.s2 .scenario-num { background: #dd6b20; }
.s3 .scenario-num { background: #c53030; }
.scenario-text-cell { display: table-cell; vertical-align: middle; padding-left: 12px; }
.scenario-text-cell h2 { font-size: 11pt; font-weight: bold; margin-bottom: 3px; }
.scenario-text-cell p  { font-size: 9pt; color: #555; }
.scenario-text-cell .just { font-size: 8.5pt; font-style: italic; margin-top: 4px; }

/* 4 PILLARS GRID */
.pillars { display: table; width: 100%; border-collapse: separate; border-spacing: 8px; margin-bottom: 14px; }
.pillar-row { display: table-row; }
.pillar { display: table-cell; width: 25%; border-radius: 8px; border: 1px solid #e0e0e0; padding: 10px 12px; vertical-align: top; }
.pillar.p-green  { border-top: 3px solid #38a169; }
.pillar.p-yellow { border-top: 3px solid #ecc94b; }
.pillar.p-orange { border-top: 3px solid #dd6b20; }
.pillar.p-red    { border-top: 3px solid #c53030; }
.pillar.p-secondary { border-top: 3px solid #adb5bd; }
.pillar-title { font-size: 7pt; font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px; color: #777; margin-bottom: 4px; }
.pillar-value { font-size: 16pt; font-weight: 900; margin-bottom: 2px; }
.pillar-sub   { font-size: 7pt; color: #888; margin-bottom: 8px; }
.badge {
    display: inline-block; border-radius: 20px;
    padding: 2px 8px; font-size: 7pt; font-weight: bold; text-transform: uppercase;
}
.badge-green  { background: #d4edda; color: #155724; }
.badge-yellow { background: #fff3cd; color: #856404; }
.badge-orange { background: #ffe5cc; color: #8a4700; }
.badge-red    { background: #f8d7da; color: #721c24; }
.badge-secondary { background: #e9ecef; color: #6c757d; }

/* DETAIL TABLE */
.detail { width: 100%; border-collapse: collapse; font-size: 8.5pt; margin-top: 6px; }
.detail td { padding: 3px 0; border-bottom: 1px solid #f0f0f0; }
.detail td:first-child { color: #666; width: 60%; }
.detail td:last-child  { text-align: right; font-weight: bold; }

/* PHRASE CABINET */
.phrase-cabinet {
    background: #f0f6ff;
    border-left: 4px solid #2d6da6;
    border-radius: 6px;
    padding: 12px 16px;
    margin-bottom: 14px;
    font-size: 9.5pt;
    font-style: italic;
    color: #1e4b7a;
    line-height: 1.6;
}
.phrase-cabinet .phrase-label {
    font-size: 7pt; font-style: normal; font-weight: bold;
    text-transform: uppercase; letter-spacing: 1px; color: #2d6da6; margin-bottom: 6px;
}

/* ATTENTION POINTS */
.attn-section { margin-bottom: 14px; }
.section-title {
    font-size: 7.5pt; font-weight: bold; text-transform: uppercase;
    letter-spacing: 1px; color: #888; border-bottom: 1px solid #e9ecef;
    padding-bottom: 4px; margin-bottom: 8px;
}
.attn-item {
    background: #f8f9fa; border-radius: 6px; border: 1px solid #e9ecef;
    padding: 7px 10px; margin-bottom: 5px; font-size: 8.5pt;
}
.attn-item strong { color: #1e4b7a; }

/* THRESHOLDS TABLE */
.thresholds { width: 100%; border-collapse: collapse; font-size: 8pt; }
.thresholds th, .thresholds td { border: 1px solid #e0e0e0; padding: 4px 6px; text-align: center; }
.thresholds th { background: #f0f4f8; font-weight: bold; }
.thresholds td:first-child { text-align: left; }

/* FOOTER */
.footer {
    border-top: 1px solid #ddd;
    margin-top: 16px;
    padding-top: 8px;
    font-size: 7pt;
    color: #999;
    display: table;
    width: 100%;
}
.footer .fl { display: table-cell; }
.footer .fr { display: table-cell; text-align: right; }
</style>
</head>
<body>
<div class="page">

    <!-- HEADER -->
    <div class="header">
        <div class="header-left">
            <div class="sub">BANQUE CENTRALE DU CONGO</div>
            <h1>🏦 Fiche Quotidienne — Stabilité Monétaire &amp; Taux de Change</h1>
            <div class="sub" style="margin-top: 6px; font-size: 10pt; font-weight: 600; color: #ffd700; opacity: 1;">Analyse du {{ date ? date|date('d \\m\\o\\i\\s Y') : 'N/D' }}</div>
        </div>
        <div class="header-right">
            <div class="date-badge">{{ date ? date|date('d/m/Y') : 'N/D' }}</div>
            <div class="confidential">Usage interne — Cabinet</div>
        </div>
    </div>

    <!-- SCÉNARIO -->
    <div class="scenario-banner s{{ scenario.scenario }}">
        <div class="scenario-num-cell">
            <div class="scenario-num">{{ scenario.scenario }}</div>
        </div>
        <div class="scenario-text-cell">
            <h2>Scénario recommandé : {{ scenario.label }}</h2>
            <p>
                {% if scenario.scenario == 1 %}Maintenir la posture actuelle. Surveillance renforcée.
                {% elseif scenario.scenario == 2 %}Renforcer la stérilisation, ajuster le signal de change, coordonner avec le Trésor.
                {% else %}Absorption massive de liquidité, intervention FX ciblée, coordination urgente Trésor–BCC.{% endif %}
            </p>
            {% if scenario.justification %}
            <div class="just">ℹ️ {{ scenario.justification }}</div>
            {% endif %}
        </div>
    </div>

    <!-- 4 PILLARS -->
    <table class="pillars">
        <tr class="pillar-row">
            <!-- Pilier 1 : Change -->
            <td class="pillar p-{{ signalChange }}">
                <div class="pillar-title">Pilier 1 — Change</div>
                <div class="pillar-value">
                    {% if ecartPct is not null %}{{ ecartPct|number_format(2, ',') }}%{% else %}N/D{% endif %}
                </div>
                <div class="pillar-sub">Écart moyen indic./parallèle</div>
                <span class="badge badge-{{ signalChange }}">
                    {{ {green:'🟢 Normal',yellow:'🟡 Vigilance',orange:'🟠 Alerte',red:'🔴 Critique',secondary:'⚪ N/D'}[signalChange] ?? signalChange }}
                </span>
                <table class="detail">
                    <tr><td>Indicatif</td><td>{{ marche ? marche.coursIndicatif|number_format(4,',') : 'N/D' }} CDF</td></tr>
                    <tr><td>Parallèle A/V</td><td>{% if marche %}{{ marche.paralleleAchat|number_format(2,',') }}/{{ marche.paralleleVente|number_format(2,',') }}{% else %}N/D{% endif %}</td></tr>
                    <tr><td>Écart absolu</td><td>{{ marche ? marche.ecartIndicParallele|number_format(2,',') : 'N/D' }} CDF</td></tr>
                    <tr><td>Écart max %</td><td>{% if ecartMaxPct is not null %}{{ ecartMaxPct|number_format(2,',') }}%{% else %}N/D{% endif %}</td></tr>
                </table>
            </td>

            <!-- Pilier 2 : Réserves -->
            <td class="pillar p-{{ signalReserves ?? 'secondary' }}">
                <div class="pillar-title">Pilier 2 — Réserves</div>
                <div class="pillar-value">
                    {% if reserves and reserves.reservesInternationalesUsd %}
                        {{ (reserves.reservesInternationalesUsd / 1000)|number_format(2,',') }} Md$
                    {% else %}N/D{% endif %}
                </div>
                <div class="pillar-sub">Réserves internationales</div>
                <span class="badge badge-{{ signalReserves ?? 'secondary' }}">
                    {{ {green:'🟢 Normal',yellow:'🟡 Vigilance',orange:'🟠 Alerte',red:'🔴 Critique',secondary:'⚪ N/D'}[signalReserves ?? 'secondary'] ?? '' }}
                </span>
                <table class="detail">
                    <tr><td>Rés. int. (Mios $)</td><td>{{ reserves ? reserves.reservesInternationalesUsd|number_format(2,',',' ') : 'N/D' }}</td></tr>
                    <tr><td>Avoirs ext. (Mios $)</td><td>{{ reserves ? reserves.avoirsExternesUsd|number_format(2,',',' ') : 'N/D' }}</td></tr>
                    <tr><td>Couverture / {{ (seuilReservesOptimal / 1000)|number_format(0) }}Md$</td>
                        <td>{% if reserves and reserves.reservesInternationalesUsd and seuilReservesOptimal > 0 %}{{ (reserves.reservesInternationalesUsd / seuilReservesOptimal * 100)|number_format(0) }}%{% else %}N/D{% endif %}</td></tr>
                </table>
            </td>

            <!-- Pilier 3 : Marché Monétaire -->
            <td class="pillar p-{{ signalMarcheMonetaire }}">
                <div class="pillar-title">Pilier 3 — Marché Monétaire</div>
                <div class="pillar-value">
                    {% if reserves and reserves.avoirsLibresCdf %}{{ reserves.avoirsLibresCdf|number_format(0,',',' ') }}{% else %}N/D{% endif %}
                </div>
                <div class="pillar-sub">Avoirs libres (Mds CDF)</div>
                <span class="badge badge-{{ signalMarcheMonetaire }}">
                    {{ {green:'🟢 Normal',yellow:'🟡 Vigilance',orange:'🟠 Alerte',red:'🔴 Critique',secondary:'⚪ N/D'}[signalMarcheMonetaire] ?? signalMarcheMonetaire }}
                </span>
                <table class="detail">
                    <tr><td>Réserves banques</td><td>{{ reserves ? reserves.reservesBanquesCdf|number_format(0,',',' ') : 'N/D' }}</td></tr>
                    <tr><td>Encours OT-BCC</td><td>{% if encours and encours.encoursOtBcc is not null %}{{ encours.encoursOtBcc|number_format(2,',',' ') }}{% else %}N/D{% endif %}</td></tr>
                    <tr><td>Encours B-BCC</td><td>{% if encours and encours.encoursBBcc is not null %}{{ encours.encoursBBcc|number_format(2,',',' ') }}{% else %}N/D{% endif %}</td></tr>
                    <tr><td>Ratio stérilisation</td><td>{% if ratioEncoursBons is not null %}{{ ratioEncoursBons|number_format(2,',') }}{% else %}N/D{% endif %}</td></tr>
                    <tr><td>Taux moyen pondéré</td><td>{% if tauxMoyenPondere is not null %}{{ tauxMoyenPondere|number_format(2,',') }} %{% else %}N/D{% endif %}</td></tr>
                    <tr><td>Masse monétaire</td><td>{% if billetsEnCirculation is not null %}{{ billetsEnCirculation|number_format(2,',',' ') }}{% else %}N/D{% endif %}</td></tr>
                   {# <tr><td>Taux interbancaire</td><td>{% if tauxInterbancaire is not null %}{{ tauxInterbancaire|number_format(2,',') }} %{% else %}N/D{% endif %}</td></tr> #}
                </table>
            </td>

            <!-- Pilier 4 : Trésorerie -->
            <td class="pillar p-{{ signalTresorerie }}">
                <div class="pillar-title">Pilier 4 — Trésorerie</div>
                <div class="pillar-value">
                    {% if tresorerie and tresorerie.soldeAvantFin %}{{ tresorerie.soldeAvantFin|number_format(0,',',' ') }}{% else %}N/D{% endif %}
                </div>
                <div class="pillar-sub">Solde avant fin (Mds CDF)</div>
                <span class="badge badge-{{ signalTresorerie }}">
                    {{ {green:'🟢 Normal',yellow:'🟡 Vigilance',orange:'🟠 Alerte',red:'🔴 Critique',secondary:'⚪ N/D'}[signalTresorerie] ?? signalTresorerie }}
                </span>
                <table class="detail">
                    <tr><td>Recettes</td><td>{{ finances ? finances.recettesTotales|number_format(2,',',' ') : 'N/D' }}</td></tr>
                    <tr><td>Dépenses</td><td>{{ finances ? finances.depensesTotales|number_format(2,',',' ') : 'N/D' }}</td></tr>
                    <tr><td>Paie exécutée</td>
                        <td>{% if tauxPaie is not null %}{{ tauxPaie|number_format(1,',') }}%{% else %}N/D{% endif %}
                            <span class="badge badge-{{ signalPaie }}">
                                {{ {green:'✓',yellow:'⚠',orange:'⚠',red:'✗',secondary:'—'}[signalPaie] ?? '' }}
                            </span>
                        </td></tr>
                    <tr><td>Reste paie</td><td>{{ paie ? paie.montantRestant|number_format(2,',',' ') : 'N/D' }}</td></tr>
                </table>
            </td>
        </tr>
    </table>

    <!-- PHRASE CABINET -->
    <div class="phrase-cabinet">
        <div class="phrase-label">🗣️ Synthèse — Niveau Cabinet</div>
        {{ phraseCabinet }}
    </div>

    <!-- ATTENTION POINTS -->
    <div class="attn-section">
        <div class="section-title">Points d'attention immédiats</div>
        {% if signalChange in ['orange','red'] %}
        <div class="attn-item">
            🟠 <strong>Désalignement de change :</strong>
            Écart moyen {% if ecartPct %}{{ ecartPct|number_format(1,',') }}%{% endif %}.
            Vérifier la cohérence du taux indicatif.
        </div>
        {% endif %}
        {% if signalMarcheMonetaire in ['orange','red'] %}
        <div class="attn-item">
            💧 <strong>Surliquidité bancaire :</strong>
            Avoirs libres {% if reserves %}{{ reserves.avoirsLibresCdf|number_format(0,',',' ') }} Mds CDF{% endif %}.
            Renforcer la stérilisation sur le Marché Monétaire.
        </div>
        {% endif %}
        {% if signalTresorerie in ['yellow','orange','red'] %}
        <div class="attn-item">
            🏛️ <strong>Tension de trésorerie :</strong>
            Solde avant fin {% if tresorerie %}{{ tresorerie.soldeAvantFin|number_format(0,',',' ') }} Mds{% endif %}.
        </div>
        {% endif %}
        {% if signalPaie in ['orange','red'] %}
        <div class="attn-item">
            💼 <strong>Choc de paie à venir :</strong>
            Reste {% if paie %}{{ paie.montantRestant|number_format(0,',',' ') }} Mds{% endif %}
            ({% if pctRestePaie %}{{ pctRestePaie|number_format(0) }}%{% endif %} non exécuté).
        </div>
        {% endif %}
        {% if signalChange == 'green' and signalLiquidite == 'green' and signalTresorerie == 'green' %}
        <div class="attn-item">✅ <strong>Situation favorable :</strong> Tous les indicateurs principaux dans les normes.</div>
        {% endif %}
    </div>

    <!-- THRESHOLDS REFERENCE -->
    <div class="attn-section">
        <div class="section-title">Seuils d'alerte de référence</div>
        <table class="thresholds">
            <thead>
                <tr>
                    <th>Indicateur</th>
                    <th>🟢 Normal</th>
                    <th>🟡 Vigilance</th>
                    <th>🟠 Alerte</th>
                    <th>🔴 Critique</th>
                </tr>
            </thead>
            <tr><td>Écart moyen indic./parallèle</td><td>≤ 2%</td><td>2–3%</td><td>3–5%</td><td>&gt; 5%</td></tr>
            <tr><td>Écart max (borne haute)</td><td>≤ 3%</td><td>—</td><td>3–6%</td><td>&gt; 6%</td></tr>
            <tr><td>Avoirs libres (Mds CDF)</td><td>&lt; 800</td><td>—</td><td>800–1 200</td><td>&gt; 1 200</td></tr>
            <tr><td>Solde trésorerie avant fin</td><td>&gt; 0</td><td>0 à −100</td><td>—</td><td>&lt; −100</td></tr>
            <tr><td>Reste paie / total</td><td>—</td><td>&lt; 20%</td><td>20–50%</td><td>&gt; 50%</td></tr>
        </table>
    </div>

    <!-- FOOTER -->
    <div class="footer">
        <div class="fl">BCC-Flex · Document généré le {{ "now"|date('d/m/Y à H:i') }}</div>
        <div class="fr">Usage interne — Confidentiel Cabinet</div>
    </div>

</div>
</body>
</html>
